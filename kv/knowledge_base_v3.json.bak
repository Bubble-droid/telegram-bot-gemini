                            "sing_box_1.11.0": {
                                "title": "Changes in sing-box 1.11.0",
                                "features": [
                                    "[action](#action)",
                                    "[server](#server) (Deprecated)",
                                    "[disable_cache](#disable_cache) (Deprecated)",
                                    "[rewrite_ttl](#rewrite_ttl) (Deprecated)",
