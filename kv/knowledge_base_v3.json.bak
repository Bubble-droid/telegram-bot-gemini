                    "or_custom_build": {
                        "title": "Or",
                        "command": "go build -tags \"tag_a tag_b\" ./cmd/sing-box"
                    },
                    "build_tags": {
                        "title": ":material-folder-settings: Build Tags",
                        "table": {
                            "headers": [
                                "Build Tag",
                                "Enabled by default",
                                "Description"
                            ],
                            "rows": [
                                {
                                    "tag": "`with_quic`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with QUIC support, see [QUIC and HTTP3 DNS transports](/configuration/dns/server/), [Naive inbound](/configuration/inbound/naive/), [Hysteria Inbound](/configuration/inbound/hysteria/), [Hysteria Outbound](/configuration/outbound/hysteria/) and [V2Ray Transport#QUIC](/configuration/shared/v2ray-transport#quic)."
                                },
                                {
                                    "tag": "`with_grpc`",
                                    "enabled_by_default": ":material-close:️",
                                    "description": "Build with standard gRPC support, see [V2Ray Transport#gRPC](/configuration/shared/v2ray-transport#grpc)."
                                },
                                {
                                    "tag": "`with_dhcp`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with DHCP support, see [DHCP DNS transport](/configuration/dns/server/)."
                                },
                                {
                                    "tag": "`with_wireguard`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with WireGuard support, see [WireGuard outbound](/configuration/outbound/wireguard/)."
                                },
                                {
                                    "tag": "`with_utls`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with [uTLS](https://github.com/refraction-networking/utls) support for TLS outbound, see [TLS](/configuration/shared/tls#utls)."
                                },
                                {
                                    "tag": "`with_reality_server`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with reality TLS server support,  see [TLS](/configuration/shared/tls/)."
                                },
                                {
                                    "tag": "`with_acme`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with ACME TLS certificate issuer support, see [TLS](/configuration/shared/tls/)."
                                },
                                {
                                    "tag": "`with_clash_api`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with Clash API support, see [Experimental](/configuration/experimental#clash-api-fields)."
                                },
                                {
                                    "tag": "`with_v2ray_api`",
                                    "enabled_by_default": ":material-close:️",
                                    "description": "Build with V2Ray API support, see [Experimental](/configuration/experimental#v2ray-api-fields)."
                                },
                                {
                                    "tag": "`with_gvisor`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with gVisor support, see [Tun inbound](/configuration/inbound/tun#stack) and [WireGuard outbound](/configuration/outbound/wireguard#system_interface)."
                                },
                                {
                                    "tag": "`with_embedded_tor` (CGO required)",
                                    "enabled_by_default": ":material-close:️",
                                    "description": "Build with embedded Tor support, see [Tor outbound](/configuration/outbound/tor/)."
                                },
                                {
                                    "tag": "`with_tailscale`",
                                    "enabled_by_default": ":material-check:",
                                    "description": "Build with Tailscale support, see [Tailscale endpoint](/configuration/endpoint/tailscale)"
                                }
                            ]
                        },
                        "note": "It is not recommended to change the default build tag list unless you really know what you are adding."
                    }
                }
