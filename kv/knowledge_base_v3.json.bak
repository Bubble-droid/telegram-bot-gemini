                        "fakeip": {
                            "title": "Fake IP",
                            "description": "Configuration for a Fake IP DNS server.",
                            "since": "Since sing-box 1.12.0",
                            "structure": {
                                "title": "Structure",
                                "json": {
                                    "dns": {
                                        "servers": [
                                            {
                                                "type": "fakeip",
                                                "tag": "",
                                                "inet4_range": "198.18.0.0/15",
                                                "inet6_range": "fc00::/18"
                                            }
                                        ]
                                    }
                                }
                            },
                            "fields": {
                                "title": "Fields",
                                "inet4_range": {
                                    "title": "inet4_range",
                                    "description": "IPv4 address range for FakeIP."
