                    "rule_action": {
                        "title": "Rule Actions",
                        "description": "Defines actions to be taken for route rules.",
                        "changes": {
                            "sing_box_1.12.0": {
                                "title": "Changes in sing-box 1.12.0",
                                "features": [
                                    "[tls_fragment](#tls_fragment)",
                                    "[tls_fragment_fallback_delay](#tls_fragment_fallback_delay)",
                                    "[resolve.disable_cache](#disable_cache)",
                                    "[resolve.rewrite_ttl](#rewrite_ttl)",
                                    "[resolve.client_subnet](#client_subnet)"
                                ]
                            }
                        },
                        "final_actions": {
                            "title": "Final actions",
                            "route": {
                                "title": "route",
                                "description": "`route` inherits the classic rule behavior of routing connection to the specified outbound.",
                                "json": {
                                    "action": "route",
                                    "outbound": "",
                                    "route_options_fields": "... // route-options Fields"
                                },
                                "fields": {
                                    "outbound": {
                                        "title": "outbound",
                                        "description": "Tag of target outbound.",
                                        "required": true
                                    }
                                }
                            },
                            "reject": {
                                "title": "reject",
                                "description": "`reject` reject connections. The specified method is used for reject tun connections if `sniff` action has not been performed yet. For non-tun connections and already established connections, will just be closed.",
                                "json": {
                                    "action": "reject",
                                    "method": "default",
                                    "no_drop": false
                                },
                                "fields": {
                                    "method": {
                                        "title": "method",
                                        "description": "- `default`: Reply with TCP RST for TCP connections, and ICMP port unreachable for UDP packets. - `drop`: Drop packets. `default` will be used by default."
                                    },
                                    "no_drop": {
                                        "title": "no_drop",
                                        "description": "If not enabled, `method` will be temporarily overwritten to `drop` after 50 triggers in 30s. Not available when `method` is set to drop."
                                    }
                                }
                            },
                            "hijack_dns": {
                                "title": "hijack-dns",
                                "description": "`hijack-dns` hijack DNS requests to the sing-box DNS module.",
                                "json": {
                                    "action": "hijack-dns"
                                }
                            }
                        },
                        "non_final_actions": {
                            "title": "Non-final actions",
                            "route_options": {
                                "title": "route-options",
                                "description": "`route-options` set options for routing.",
                                "json": {
                                    "action": "route-options",
                                    "override_address": "",
                                    "override_port": 0,
                                    "network_strategy": "",
                                    "fallback_delay": "",
                                    "udp_disable_domain_unmapping": false,
                                    "udp_connect": false,
                                    "udp_timeout": "",
                                    "tls_fragment": false,
                                    "tls_fragment_fallback_delay": ""
                                },
                                "fields": {
                                    "override_address": {
                                        "title": "override_address",
                                        "description": "Override the connection destination address."
                                    },
                                    "override_port": {
                                        "title": "override_port",
                                        "description": "Override the connection destination port."
                                    },
                                    "network_strategy": {
                                        "title": "network_strategy",
                                        "description": "See [Dial Fields](/configuration/shared/dial/#network_strategy) for details. Only take effect if outbound is direct without `outbound.bind_interface`, `outbound.inet4_bind_address` and `outbound.inet6_bind_address` set."
                                    },
                                    "network_type": {
                                        "title": "network_type",
                                        "description": "See [Dial Fields](/configuration/shared/dial/#network_type) for details."
                                    },
                                    "fallback_network_type": {
                                        "title": "fallback_network_type",
                                        "description": "See [Dial Fields](/configuration/shared/dial/#fallback_network_type) for details."
                                    },
                                    "fallback_delay": {
                                        "title": "fallback_delay",
                                        "description": "See [Dial Fields](/configuration/shared/dial/#fallback_delay) for details."
                                    },
                                    "udp_disable_domain_unmapping": {
                                        "title": "udp_disable_domain_unmapping",
                                        "description": "If enabled, for UDP proxy requests addressed to a domain, the original packet address will be sent in the response instead of the mapped domain. This option is used for compatibility with clients that do not support receiving UDP packets with domain addresses, such as Surge."
                                    },
                                    "udp_connect": {
                                        "title": "udp_connect",
                                        "description": "If enabled, attempts to connect UDP connection to the destination instead of listen."
                                    },
                                    "udp_timeout": {
                                        "title": "udp_timeout",
                                        "description": "Timeout for UDP connections. Setting a larger value than the UDP timeout in inbounds will have no effect. Default value for protocol sniffed connections:",
                                        "table": {
                                            "headers": [
                                                "Timeout",
                                                "Protocol"
                                            ],
                                            "rows": [
                                                {
                                                    "timeout": "`10s`",
                                                    "protocol": "`dns`, `ntp`, `stun`"
                                                },
                                                {
                                                    "timeout": "`30s`",
                                                    "protocol": "`quic`, `dtls`"
                                                }
                                            ],
                                            "default_note": "If no protocol is sniffed, the following ports will be recognized as protocols by default:",
                                            "default_table": {
                                                "headers": [
                                                    "Port",
                                                    "Protocol"
                                                ],
                                                "rows": [
                                                    {
                                                        "port": "53",
                                                        "protocol": "`dns`"
                                                    },
                                                    {
                                                        "port": "123",
                                                        "protocol": "`ntp`"
                                                    },
                                                    {
                                                        "port": "443",
                                                        "protocol": "`quic`"
                                                    },
                                                    {
                                                        "port": "3478",
                                                        "protocol": "`stun`"
                                                    }
                                                ]
                                            }
                                        }
                                    },
                                    "tls_fragment": {
                                        "title": "tls_fragment",
                                        "description": "Fragment TLS handshakes to bypass firewalls. This feature is intended to circumvent simple firewalls based on **plaintext packet matching**, and should not be used to circumvent real censorship. Since it is not designed for performance, it should not be applied to all connections, but only to server names that are known to be blocked. On Linux, Apple platforms, (administrator privileges required) Windows, the wait time can be automatically detected, otherwise it will fall back to waiting for a fixed time specified by `tls_fragment_fallback_delay`.",
                                        "since": "Since sing-box 1.12.0"
                                    },
                                    "tls_fragment_fallback_delay": {
                                        "title": "tls_fragment_fallback_delay",
                                        "description": "The fallback value used when TLS segmentation cannot automatically determine the wait time. `500ms` is used by default.",
                                        "since": "Since sing-box 1.12.0"
                                    }
                                }
                            },
                            "sniff": {
                                "title": "sniff",
                                "description": "`sniff` performs protocol sniffing on connections. For deprecated `inbound.sniff` options, it is considered to `sniff()` performed before routing.",
                                "json": {
                                    "action": "sniff",
                                    "sniffer": [],
                                    "timeout": ""
                                },
                                "fields": {
                                    "sniffer": {
                                        "title": "sniffer",
                                        "description": "Enabled sniffers. All sniffers enabled by default. Available protocol values an be found on in [Protocol Sniff](../sniff/)"
                                    },
                                    "timeout": {
                                        "title": "timeout",
                                        "description": "Timeout for sniffing. `300ms` is used by default."
                                    }
                                }
                            },
                            "resolve": {
                                "title": "resolve",
                                "description": "`resolve` resolve request destination from domain to IP addresses.",
                                "json": {
                                    "action": "resolve",
                                    "server": "",
                                    "strategy": "",
                                    "disable_cache": false,
                                    "rewrite_ttl": null,
                                    "client_subnet": null
                                },
                                "fields": {
                                    "server": {
                                        "title": "server",
                                        "description": "Specifies DNS server tag to use instead of selecting through DNS routing."
                                    },
                                    "strategy": {
                                        "title": "strategy",
                                        "description": "DNS resolution strategy, available values are: `prefer_ipv4`, `prefer_ipv6`, `ipv4_only`, `ipv6_only`. `dns.strategy` will be used by default."
                                    },
                                    "disable_cache": {
                                        "title": "disable_cache",
                                        "description": "Disable cache and save cache in this query.",
                                        "since": "Since sing-box 1.12.0"
                                    },
                                    "rewrite_ttl": {
                                        "title": "rewrite_ttl",
                                        "description": "Rewrite TTL in DNS responses.",
                                        "since": "Since sing-box 1.12.0"
                                    },
                                    "client_subnet": {
                                        "title": "client_subnet",
                                        "description": "Append a `edns0-subnet` OPT extra record with the specified IP prefix to every query by default. If value is an IP address instead of prefix, `/32` or `/128` will be appended automatically. Will overrides `dns.client_subnet`.",
                                        "since": "Since sing-box 1.12.0"
                                    }
                                }
                            }
                        }
                    },
                    "sniff": {
                        "title": "Protocol Sniff",
                        "description": "If enabled in the inbound, the protocol and domain name (if present) of by the connection can be sniffed.",
