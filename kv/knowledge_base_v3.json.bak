                    "cache-file": {
                        "title": "Cache File",
                        "description": "Configuration for caching DNS responses to a file.",
                        "since": "Since sing-box 1.8.0",
                        "changes": {
                            "sing_box_1.9.0": {
                                "title": "Changes in sing-box 1.9.0",
                                "features": [
                                    "[store_rdrc](#store_rdrc)",
                                    "[rdrc_timeout](#rdrc_timeout)"
                                ]
                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "enabled": true,
                                "path": "",
                                "cache_id": "",
                                "store_fakeip": false,
                                "store_rdrc": false,
                                "rdrc_timeout": ""
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "enabled": {
                                "title": "enabled",
                                "description": "Enable cache file."
                            },
                            "path": {
                                "title": "path",
                                "description": "Path to the cache file. `cache.db` will be used if empty."
                            },
                            "cache_id": {
                                "title": "cache_id",
                                "description": "Identifier in the cache file. If not empty, configuration specified data will use a separate store keyed by it."
                            },
                            "store_fakeip": {
                                "title": "store_fakeip",
                                "description": "Store fakeip in the cache file"
                            },
                            "store_rdrc": {
                                "title": "store_rdrc",
                                "description": "Store rejected DNS response cache in the cache file. The check results of [Address filter DNS rule items](/configuration/dns/rule/#address-filter-fields) will be cached until expiration.",
                                "since": "Since sing-box 1.9.0"
                            },
                            "rdrc_timeout": {
                                "title": "rdrc_timeout",
                                "description": "Timeout of rejected DNS response cache. `7d` is used by default.",
                                "since": "Since sing-box 1.9.0"
                            }
                        }
                    },
                    "clash-api": {
                        "title": "Clash API",
                        "description": "Configuration for the Clash API.",
                        "changes": {
                            "sing_box_1.10.0": {
                                "title": "Changes in sing-box 1.10.0",
                                "features": [
                                    "[access_control_allow_origin](#access_control_allow_origin)",
                                    "[access_control_allow_private_network](#access_control_allow_private_network)"
                                ]
                            },
                            "sing_box_1.8.0": {
                                "title": "Changes in sing-box 1.8.0",
                                "features": [
                                    "[store_mode](#store_mode) (Deprecated)",
                                    "[store_selected](#store_selected) (Deprecated)",
                                    "[store_fakeip](#store_fakeip) (Deprecated)",
                                    "[cache_file](#cache_file) (Deprecated)",
                                    "[cache_id](#cache_id) (Deprecated)"
                                ]
                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "external_controller": "127.0.0.1:9090",
                                "external_ui": "",
                                "external_ui_download_url": "",
                                "external_ui_download_detour": "",
                                "secret": "",
                                "default_mode": "",
                                "access_control_allow_origin": [],
                                "access_control_allow_private_network": false,
                                "store_mode": false,
                                "store_selected": false,
                                "store_fakeip": false,
                                "cache_file": "",
                                "cache_id": ""
                            }
                        },
                        "examples": {
                            "online": {
                                "title": "Example (online)",
                                "since": "Since sing-box 1.10.0",
                                "json": {
                                    "external_controller": "127.0.0.1:9090",
                                    "access_control_allow_origin": [
                                        "http://127.0.0.1",
                                        "http://yacd.haishan.me"
                                    ],
                                    "access_control_allow_private_network": true
                                }
                            },
                            "download": {
                                "title": "Example (download)",
                                "since": "Since sing-box 1.10.0",
                                "json": {
                                    "external_controller": "0.0.0.0:9090",
                                    "external_ui": "dashboard",
                                    "external_ui_download_detour": "direct"
                                }
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "external_controller": {
                                "title": "external_controller",
                                "description": "RESTful web API listening address. Clash API will be disabled if empty."
                            },
                            "external_ui": {
                                "title": "external_ui",
                                "description": "A relative path to the configuration directory or an absolute path to a directory in which you put some static web resource. sing-box will then serve it at `http://{{external-controller}}/ui`."
                            },
                            "external_ui_download_url": {
                                "title": "external_ui_download_url",
                                "description": "ZIP download URL for the external UI, will be used if the specified `external_ui` directory is empty. `https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip` will be used if empty."
                            },
                            "external_ui_download_detour": {
                                "title": "external_ui_download_detour",
                                "description": "The tag of the outbound to download the external UI. Default outbound will be used if empty."
                            },
                            "secret": {
                                "title": "secret",
                                "description": "Secret for the RESTful API (optional) Authenticate by spedifying HTTP header `Authorization: Bearer ${secret}` ALWAYS set a secret if RESTful API is listening on 0.0.0.0"
                            },
                            "default_mode": {
                                "title": "default_mode",
                                "description": "Default mode in clash, `Rule` will be used if empty. This setting has no direct effect, but can be used in routing and DNS rules via the `clash_mode` rule item."
                            },
                            "access_control_allow_origin": {
                                "title": "access_control_allow_origin",
                                "description": "CORS allowed origins, `*` will be used if empty. To access the Clash API on a private network from a public website, you must explicitly specify it in `access_control_allow_origin` instead of using `*`.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "access_control_allow_private_network": {
                                "title": "access_control_allow_private_network",
                                "description": "Allow access from private network. To access the Clash API on a private network from a public website, `access_control_allow_private_network` must be enabled.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "store_mode": {
                                "title": "store_mode",
                                "description": "`store_mode` is deprecated in Clash API and enabled by default if `cache_file.enabled`.",
                                "deprecated": "Deprecated in sing-box 1.8.0"
                            },
                            "store_selected": {
                                "title": "store_selected",
                                "description": "`store_selected` is deprecated in Clash API and enabled by default if `cache_file.enabled`. The tag must be set for target outbounds. Store selected outbound for the `Selector` outbound in cache file.",
                                "deprecated": "Deprecated in sing-box 1.8.0"
                            },
                            "store_fakeip": {
                                "title": "store_fakeip",
                                "description": "`store_selected` is deprecated in Clash API and migrated to `cache_file.store_fakeip`. Store fakeip in cache file.",
                                "deprecated": "Deprecated in sing-box 1.8.0"
                            },
                            "cache_file": {
                                "title": "cache_file",
                                "description": "`cache_file` is deprecated in Clash API and migrated to `cache_file.enabled` and `cache_file.path`. Cache file path, `cache.db` will be used if empty.",
                                "deprecated": "Deprecated in sing-box 1.8.0"
                            },
                            "cache_id": {
                                "title": "cache_id",
                                "description": "`cache_id` is deprecated in Clash API and migrated to `cache_file.cache_id`. Identifier in cache file. If not empty, configuration specified data will use a separate store keyed by it.",
                                "deprecated": "Deprecated in sing-box 1.8.0"
                            }
                        }
                    }
                },
                "shared": {
                    "listen": {
                        "title": "Listen Fields",
                        "description": "Common configuration fields for inbounds.",
                        "changes": {
                            "sing_box_1.11.0": {
                                "title": "Changes in sing-box 1.11.0",
                                "features": [
                                    "[sniff](#sniff) (Deprecated)",
                                    "[sniff_override_destination](#sniff_override_destination) (Deprecated)",
                                    "[sniff_timeout](#sniff_timeout) (Deprecated)",
                                    "[domain_strategy](#domain_strategy) (Deprecated)",
                                    "[udp_disable_domain_unmapping](#udp_disable_domain_unmapping) (Deprecated)"
                                ]
                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "listen": "::",
                                "listen_port": 5353,
                                "tcp_fast_open": false,
                                "tcp_multi_path": false,
                                "udp_fragment": false,
                                "udp_timeout": "5m",
                                "detour": "another-in",
                                "sniff": false,
                                "sniff_override_destination": false,
                                "sniff_timeout": "300ms",
                                "domain_strategy": "prefer_ipv6",
                                "udp_disable_domain_unmapping": false
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "listen": {
                                "title": "listen",
                                "description": "Listen address.",
                                "required": true
                            },
                            "listen_port": {
                                "title": "listen_port",
                                "description": "Listen port."
                            },
                            "tcp_fast_open": {
                                "title": "tcp_fast_open",
                                "description": "Enable TCP Fast Open."
                            },
                            "tcp_multi_path": {
                                "title": "tcp_multi_path",
                                "description": "Enable TCP Multi Path.",
                                "warning": "Go 1.21 required."
                            },
                            "udp_fragment": {
                                "title": "udp_fragment",
                                "description": "Enable UDP fragmentation."
                            },
                            "udp_timeout": {
                                "title": "udp_timeout",
                                "description": "UDP NAT expiration time. `5m` will be used by default."
                            },
                            "detour": {
                                "title": "detour",
                                "description": "If set, connections will be forwarded to the specified inbound. Requires target inbound support, see [Injectable](/configuration/inbound/#fields)."
                            },
                            "sniff": {
                                "title": "sniff",
                                "description": "Enable sniffing. See [Protocol Sniff](/configuration/route/sniff/) for details.",
                                "deprecated": "Deprecated in sing-box 1.11.0 and will be removed in sing-box 1.13.0, check [Migration](/migration/#migrate-legacy-inbound-fields-to-rule-actions)."
                            },
                            "sniff_override_destination": {
                                "title": "sniff_override_destination",
                                "description": "Override the connection destination address with the sniffed domain. If the domain name is invalid (like tor), this will not work.",
                                "deprecated": "Deprecated in sing-box 1.11.0 and will be removed in sing-box 1.13.0."
                            },
                            "sniff_timeout": {
                                "title": "sniff_timeout",
                                "description": "Timeout for sniffing. `300ms` is used by default.",
                                "deprecated": "Deprecated in sing-box 1.11.0 and will be removed in sing-box 1.13.0, check [Migration](/migration/#migrate-legacy-inbound-fields-to-rule-actions)."
                            },
                            "domain_strategy": {
                                "title": "domain_strategy",
                                "description": "One of `prefer_ipv4` `prefer_ipv6` `ipv4_only` `ipv6_only`. If set, the requested domain name will be resolved to IP before routing. If `sniff_override_destination` is in effect, its value will be taken as a fallback.",
                                "deprecated": "Deprecated in sing-box 1.11.0 and will be removed in sing-box 1.13.0, check [Migration](/migration/#migrate-legacy-inbound-fields-to-rule-actions)."
                            },
                            "udp_disable_domain_unmapping": {
                                "title": "udp_disable_domain_unmapping",
                                "description": "If enabled, for UDP proxy requests addressed to a domain, the original packet address will be sent in the response instead of the mapped domain. This option is used for compatibility with clients that do not support receiving UDP packets with domain addresses, such as Surge.",
                                "deprecated": "Deprecated in sing-box 1.11.0 and will be removed in sing-box 1.13.0, check [Migration](/migration/#migrate-legacy-inbound-fields-to-rule-actions)."
                            }
                        },
                        "table": {
                            "title": "Table",
                            "headers": [
                                "Field",
                                "Available Context"
                            ],
                            "rows": [
                                {
                                    "field": "`listen`",
                                    "available_context": "Needs to listen on TCP or UDP."
                                },
                                {
                                    "field": "`listen_port`",
                                    "available_context": "Needs to listen on TCP or UDP."
                                },
                                {
                                    "field": "`tcp_fast_open`",
                                    "available_context": "Needs to listen on TCP."
                                },
                                {
                                    "field": "`tcp_multi_path`",
                                    "available_context": "Needs to listen on TCP."
                                },
                                {
                                    "field": "`udp_timeout`",
                                    "available_context": "Needs to assemble UDP connections."
                                },
                                {
                                    "field": "`udp_disable_domain_unmapping`",
                                    "available_context": "Needs to listen on UDP and accept domain UDP addresses."
                                }
                            ]
                        }
                    },
                    "dial": {
                        "title": "Dial Fields",
                        "description": "Common configuration fields for dialing connections.",
                        "changes": {
                            "sing_box_1.12.0": {
                                "title": "Changes in sing-box 1.12.0",
                                "features": [
                                    "[domain_resolver](#domain_resolver)",
                                    "[domain_strategy](#domain_strategy) (Deprecated)"
                                ]
                            },
                            "sing_box_1.11.0": {
                                "title": "Changes in sing-box 1.11.0",
                                "features": [
                                    "[network_strategy](#network_strategy)",
                                    "[fallback_delay](#fallback_delay)",
                                    "[network_type](#network_type)",
                                    "[fallback_network_type](#fallback_network_type)"
                                ]
                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "detour": "upstream-out",
                                "bind_interface": "en0",
                                "inet4_bind_address": "0.0.0.0",
                                "inet6_bind_address": "::",
                                "routing_mark": 1234,
                                "reuse_addr": false,
                                "connect_timeout": "5s",
                                "tcp_fast_open": false,
                                "tcp_multi_path": false,
                                "udp_fragment": false,
                                "domain_resolver": "",
                                "network_strategy": "",
                                "network_type": [],
                                "fallback_network_type": [],
                                "fallback_delay": "300ms",
                                "domain_strategy": "prefer_ipv6"
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "detour": {
                                "title": "detour",
                                "description": "The tag of the upstream outbound. If enabled, all other fields will be ignored."
                            },
                            "bind_interface": {
                                "title": "bind_interface",
                                "description": "The network interface to bind to."
                            },
                            "inet4_bind_address": {
                                "title": "inet4_bind_address",
                                "description": "The IPv4 address to bind to."
                            },
                            "inet6_bind_address": {
                                "title": "inet6_bind_address",
                                "description": "The IPv6 address to bind to."
                            },
                            "routing_mark": {
                                "title": "routing_mark",
                                "description": "Set netfilter routing mark.",
                                "note": "Only supported on Linux."
                            },
                            "reuse_addr": {
                                "title": "reuse_addr",
                                "description": "Reuse listener address."
                            },
                            "tcp_fast_open": {
                                "title": "tcp_fast_open",
                                "description": "Enable TCP Fast Open."
                            },
                            "tcp_multi_path": {
                                "title": "tcp_multi_path",
                                "description": "Enable TCP Multi Path.",
                                "warning": "Go 1.21 required."
                            },
                            "udp_fragment": {
                                "title": "udp_fragment",
                                "description": "Enable UDP fragmentation."
                            },
                            "connect_timeout": {
                                "title": "connect_timeout",
                                "description": "Connect timeout, in golang's Duration format. A duration string is a possibly signed sequence of decimal numbers, each with optional fraction and a unit suffix, such as \"300ms\", \"-1.5h\" or \"2h45m\". Valid time units are \"ns\", \"us\" (or \"µs\"), \"ms\", \"s\", \"m\", \"h\"."
                            },
                            "domain_resolver": {
                                "title": "domain_resolver",
                                "description": "Set domain resolver to use for resolving domain names. This option uses the same format as the [route DNS rule action](/configuration/dns/rule_action/#route) without the `action` field.",
                                "note": "`domain_resolver` or `route.default_domain_resolver` is optional when only one DNS server is configured.",
                                "warning": "`outbound` DNS rule items are deprecated and will be removed in sing-box 1.14.0, so this item will be required for outbound/endpoints using domain name in server address since sing-box 1.14.0.",
                                "string_equivalent": "Setting this option directly to a string is equivalent to setting `server` of this options.",
                                "table": {
                                    "headers": [
                                        "Outbound/Endpoints",
                                        "Effected domains"
                                    ],
                                    "rows": [
                                        {
                                            "outbound_or_endpoint": "`direct`",
                                            "effected_domains": "Domain in request"
                                        },
                                        {
                                            "outbound_or_endpoint": "others",
                                            "effected_domains": "Domain in server address"
                                        }
                                    ]
                                }
                            },
                            "network_strategy": {
                                "title": "network_strategy",
                                "description": "Strategy for selecting network interfaces.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms with `auto_detect_interface` enabled. Conflicts with `bind_interface`, `inet4_bind_address` and `inet6_bind_address`.",
                                "available_values": [
                                    "`default` (default): Connect to default network or networks specified in `network_type` sequentially.",
                                    "`hybrid`: Connect to all networks or networks specified in `network_type` concurrently.",
                                    "`fallback`: Connect to default network or preferred networks specified in `network_type` concurrently, and try fallback networks when unavailable or timeout."
                                ],
                                "fallback_note": "For fallback, when preferred interfaces fails or times out, it will enter a 15s fast fallback state (Connect to all preferred and fallback networks concurrently), and exit immediately if preferred networks recover."
                            },
                            "network_type": {
                                "title": "network_type",
                                "description": "Network types to use when using `default` or `hybrid` network strategy or preferred network types to use when using `fallback` network strategy. Device's default network is used by default.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms with `auto_detect_interface` enabled.",
                                "available_values": [
                                    "`wifi`",
                                    "`cellular`",
                                    "`ethernet`",
                                    "`other`"
                                ]
                            },
                            "fallback_network_type": {
                                "title": "fallback_network_type",
                                "description": "Fallback network types when preferred networks are unavailable or timeout when using `fallback` network strategy. All other networks expect preferred are used by default.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms with `auto_detect_interface` enabled."
                            },
                            "fallback_delay": {
                                "title": "fallback_delay",
                                "description": "The length of time to wait before spawning a RFC 6555 Fast Fallback connection. For `domain_strategy`, is the amount of time to wait for connection to succeed before assuming that IPv4/IPv6 is misconfigured and falling back to other type of addresses. For `network_strategy`, is the amount of time to wait for connection to succeed before falling back to other interfaces. Only take effect when `domain_strategy` or `network_strategy` is set. `300ms` is used by default.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms with `auto_detect_interface` enabled."
                            },
                            "domain_strategy": {
                                "title": "domain_strategy",
                                "description": "Available values: `prefer_ipv4`, `prefer_ipv6`, `ipv4_only`, `ipv6_only`. If set, the requested domain name will be resolved to IP before connect.",
                                "deprecated": "Deprecated in sing-box 1.12.0 and merged to `domain_resolver`.",
                                "table": {
                                    "headers": [
                                        "Outbound",
                                        "Effected domains",
                                        "Fallback Value"
                                    ],
                                    "rows": [
                                        {
                                            "outbound": "`direct`",
                                            "effected_domains": "Domain in request",
                                            "fallback_value": "Take `inbound.domain_strategy` if not set"
                                        },
                                        {
                                            "outbound": "others",
                                            "effected_domains": "Domain in server address",
                                            "fallback_value": "/"
                                        }
                                    ]
                                }
                            }
                        }
                    },
