                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "dhcp"
                                                            },
                                                            {
                                                                "type": "dhcp",
                                                                "interface": "en0"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "fakeip": {
                                            "deprecated": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "1.1.1.1"
                                                            },
                                                            {
                                                                "address": "fakeip",
                                                                "tag": "fakeip"
                                                            }
                                                        ],
                                                        "rules": [
                                                            {
                                                                "query_type": [
                                                                    "A",
                                                                    "AAAA"
                                                                ],
                                                                "server": "fakeip"
                                                            }
                                                        ],
                                                        "fakeip": {
                                                            "enable": true,
                                                            "inet4_range": "198.18.0.0/15",
                                                            "inet6_range": "fc00::/18"
                                                        }
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "udp",
                                                                "server": "1.1.1.1"
                                                            },
                                                            {
                                                                "type": "fakeip",
                                                                "tag": "fakeip",
                                                                "inet4_range": "198.18.0.0/15",
                                                                "inet6_range": "fc00::/18"
                                                            }
                                                        ],
                                                        "rules": [
                                                            {
                                                                "query_type": [
                                                                    "A",
                                                                    "AAAA"
                                                                ],
                                                                "server": "fakeip"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "rcode": {
                                            "deprecated": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "rcode://refused"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "predefined",
                                                                "responses": [
                                                                    {
                                                                        "rcode": "REFUSED"
                                                                    }
                                                                ]
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "servers_with_domain_address": {
                                            "deprecated": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "https://dns.google/dns-query",
                                                                "address_resolver": "google"
                                                            },
                                                            {
                                                                "tag": "google",
                                                                "address": "1.1.1.1"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "https",
                                                                "server": "dns.google",
                                                                "domain_resolver": "google"
                                                            },
                                                            {
                                                                "type": "udp",
                                                                "tag": "google",
                                                                "server": "1.1.1.1"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "servers_with_strategy": {
                                            "deprecated": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "1.1.1.1",
                                                                "strategy": "ipv4_only"
                                                            },
                                                            {
                                                                "tag": "google",
                                                                "address": "8.8.8.8",
                                                                "strategy": "prefer_ipv6"
                                                            }
                                                        ],
                                                        "rules": [
                                                            {
                                                                "domain": "google.com",
                                                                "server": "google"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "udp",
                                                                "server": "1.1.1.1"
                                                            },
                                                            {
                                                                "type": "udp",
                                                                "tag": "google",
                                                                "server": "8.8.8.8"
                                                            }
                                                        ],
                                                        "rules": [
                                                            {
                                                                "domain": "google.com",
                                                                "server": "google",
                                                                "strategy": "prefer_ipv6"
                                                            }
                                                        ],
                                                        "strategy": "ipv4_only"
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "servers_with_client_subnet": {
                                            "deprecated": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "1.1.1.1"
                                                            },
                                                            {
                                                                "tag": "google",
                                                                "address": "8.8.8.8",
                                                                "client_subnet": "1.1.1.1"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "udp",
                                                                "server": "1.1.1.1"
                                                            },
                                                            {
                                                                "type": "udp",
                                                                "tag": "google",
                                                                "server": "8.8.8.8"
                                                            }
                                                        ],
                                                        "rules": [
                                                            {
                                                                "domain": "google.com",
                                                                "server": "google",
                                                                "client_subnet": "1.1.1.1"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    }
                                ]
                            }
                        },
                        {
                            "migrate_outbound_dns_rule_items_to_domain_resolver": {
                                "description": "Migrate outbound DNS rule items to domain resolver",
                                "details": "The legacy outbound DNS rules are deprecated and can be replaced by new domain resolver options.",
                                "references": "[DNS rule](/configuration/dns/rule/#outbound) / [Dial Fields](/configuration/shared/dial/#domain_resolver) / [Route](/configuration/route/#domain_resolver)",
                                "examples": [
                                    {
                                        "deprecated": {
                                            "configuration": {
                                                "dns": {
                                                    "servers": [
                                                        {
                                                            "address": "local",
                                                            "tag": "local"
                                                        }
                                                    ],
                                                    "rules": [
                                                        {
                                                            "outbound": "any",
                                                            "server": "local"
                                                        }
                                                    ]
                                                },
                                                "outbounds": [
                                                    {
                                                        "type": "socks",
                                                        "server": "example.org",
                                                        "server_port": 2080
                                                    }
                                                ]
                                            }
                                        },
                                        "new": {
                                            "configuration": {
                                                "dns": {
                                                    "servers": [
                                                        {
                                                            "type": "local"
                                                        }
                                                    ]
                                                },
                                                "outbounds": [
                                                    {
                                                        "type": "socks",
                                                        "server": "example.org",
                                                        "server_port": 2080,
                                                        "domain_resolver": {
                                                            "server": "local",
                                                            "rewrite_ttl": 60,
                                                            "client_subnet": "1.1.1.1"
                                                        },
                                                        "or": "\"domain_resolver\": \"local\""
                                                    }
                                                ],
                                                "route": {
                                                    "default_domain_resolver": {
                                                        "server": "local",
                                                        "rewrite_ttl": 60,
                                                        "client_subnet": "1.1.1.1"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                },
                "1.11.0": {
                    "title": "1.11.0",
                    "changes": [
                        {
                            "migrate_legacy_special_outbounds_to_rule_actions": {
                                "description": "Migrate legacy special outbounds to rule actions",
                                "details": "Legacy special outbounds are deprecated and can be replaced by rule actions.",
                                "references": "[Rule Action](/configuration/route/rule_action/) / [Block](/configuration/outbound/block/) / [DNS](/configuration/outbound/dns)",
                                "examples": [
                                    {
                                        "block": {
                                            "deprecated": {
                                                "configuration": {
                                                    "outbounds": [
                                                        {
                                                            "type": "block",
                                                            "tag": "block"
                                                        }
                                                    ],
                                                    "route": {
                                                        "rules": [
                                                            {
                                                                "outbound": "block"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "route": {
                                                        "rules": [
                                                            {
                                                                "action": "reject"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "dns": {
                                            "deprecated": {
                                                "configuration": {
                                                    "inbound": [
                                                        {
                                                            "sniff": true
                                                        }
                                                    ],
                                                    "outbounds": [
                                                        {
                                                            "tag": "dns",
                                                            "type": "dns"
                                                        }
                                                    ],
                                                    "route": {
                                                        "rules": [
                                                            {
                                                                "protocol": "dns",
                                                                "outbound": "dns"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "route": {
                                                        "rules": [
                                                            {
                                                                "action": "sniff"
                                                            },
                                                            {
                                                                "protocol": "dns",
                                                                "action": "hijack-dns"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    }
                                ]
                            }
                        },
                        {
                            "migrate_legacy_inbound_fields_to_rule_actions": {
                                "description": "Migrate legacy inbound fields to rule actions",
                                "details": "Inbound fields are deprecated and can be replaced by rule actions.",
                                "references": "[Listen Fields](/configuration/shared/listen/) / [Rule](/configuration/route/rule/) / [Rule Action](/configuration/route/rule_action/) / [DNS Rule](/configuration/dns/rule/) / [DNS Rule Action](/configuration/dns/rule_action/)",
                                "examples": [
                                    {
                                        "deprecated": {
                                            "configuration": {
                                                "inbounds": [
                                                    {
                                                        "type": "mixed",
                                                        "sniff": true,
                                                        "sniff_timeout": "1s",
                                                        "domain_strategy": "prefer_ipv4"
                                                    }
                                                ]
                                            }
                                        },
                                        "new": {
                                            "configuration": {
                                                "inbounds": [
                                                    {
                                                        "type": "mixed",
                                                        "tag": "in"
                                                    }
                                                ],
                                                "route": {
                                                    "rules": [
                                                        {
                                                            "inbound": "in",
                                                            "action": "resolve",
                                                            "strategy": "prefer_ipv4"
                                                        },
                                                        {
                                                            "inbound": "in",
                                                            "action": "sniff",
                                                            "timeout": "1s"
                                                        }
                                                    ]
                                                }
                                            }
                                        }
                                    }
                                ]
                            }
                        },
                        {
                            "migrate_destination_override_fields_to_route_options": {
                                "description": "Migrate destination override fields to route options",
                                "details": "Destination override fields in direct outbound are deprecated and can be replaced by route options.",
                                "references": "[Rule Action](/configuration/route/rule_action/) / [Direct](/configuration/outbound/direct/)",
                                "examples": [
                                    {
                                        "deprecated": {
                                            "configuration": {
                                                "outbounds": [
                                                    {
                                                        "type": "direct",
                                                        "override_address": "1.1.1.1",
                                                        "override_port": 443
                                                    }
                                                ]
                                            }
                                        },
                                        "new": {
                                            "configuration": {
                                                "route": {
                                                    "rules": [
                                                        {
                                                            "action": "route-options // or route",
                                                            "override_address": "1.1.1.1",
                                                            "override_port": 443
                                                        }
                                                    ]
                                                }
                                            }
                                        }
                                    }
                                ]
                            }
                        },
                        {
                            "migrate_wireguard_outbound_to_endpoint": {
                                "description": "Migrate WireGuard outbound to endpoint",
                                "details": "WireGuard outbound is deprecated and can be replaced by endpoint.",
                                "references": "[Endpoint](/configuration/endpoint/) / [WireGuard Endpoint](/configuration/endpoint/wireguard/) / [WireGuard Outbound](/configuration/outbound/wireguard/)",
                                "examples": [
                                    {
                                        "deprecated": {
                                            "configuration": {
                                                "outbounds": [
                                                    {
                                                        "type": "wireguard",
                                                        "tag": "wg-out",
                                                        "server": "127.0.0.1",
                                                        "server_port": 10001,
                                                        "system_interface": true,
                                                        "gso": true,
                                                        "interface_name": "wg0",
                                                        "local_address": [
                                                            "10.0.0.1/32"
                                                        ],
                                                        "private_key": "<private_key>",
                                                        "peer_public_key": "<peer_public_key>",
                                                        "pre_shared_key": "<pre_shared_key>",
                                                        "reserved": [
                                                            0,
                                                            0,
                                                            0
                                                        ],
                                                        "mtu": 1408
                                                    }
                                                ]
                                            }
                                        },
                                        "new": {
                                            "configuration": {
                                                "endpoints": [
                                                    {
                                                        "type": "wireguard",
                                                        "tag": "wg-ep",
                                                        "system": true,
                                                        "name": "wg0",
                                                        "mtu": 1408,
                                                        "address": [
                                                            "10.0.0.2/32"
                                                        ],
                                                        "private_key": "<private_key>",
                                                        "listen_port": 10000,
                                                        "peers": [
                                                            {
                                                                "address": "127.0.0.1",
                                                                "port": 10001,
                                                                "public_key": "<peer_public_key>",
                                                                "pre_shared_key": "<pre_shared_key>",
                                                                "allowed_ips": [
                                                                    "0.0.0.0/0"
                                                                ],
                                                                "persistent_keepalive_interval": 30,
                                                                "reserved": [
                                                                    0,
                                                                    0,
                                                                    0
                                                                ]
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                },
                "1.10.0": {
                    "title": "1.10.0",
                    "changes": [
                        {
                            "tun_address_fields_are_merged": {
                                "description": "TUN address fields are merged",
                                "details": "`inet4_address` and `inet6_address` are merged into `address`, `inet4_route_address` and `inet6_route_address` are merged into `route_address`, `inet4_route_exclude_address` and `inet6_route_exclude_address` are merged into `route_exclude_address`.",
                                "references": "[TUN](/configuration/inbound/tun/)",
                                "examples": [
                                    {
                                        "deprecated": {
                                            "configuration": {
                                                "inbounds": [
                                                    {
                                                        "type": "tun",
                                                        "inet4_address": "172.19.0.1/30",
                                                        "inet6_address": "fdfe:dcba:9876::1/126",
                                                        "inet4_route_address": [
                                                            "0.0.0.0/1",
                                                            "128.0.0.0/1"
                                                        ],
                                                        "inet6_route_address": [
                                                            "::/1",
                                                            "8000::/1"
                                                        ],
                                                        "inet4_route_exclude_address": [
                                                            "192.168.0.0/16"
                                                        ],
                                                        "inet6_route_exclude_address": [
                                                            "fc00::/7"
                                                        ]
                                                    }
                                                ]
                                            }
                                        },
                                        "new": {
                                            "configuration": {
                                                "inbounds": [
                                                    {
                                                        "type": "tun",
                                                        "address": [
                                                            "172.19.0.1/30",
                                                            "fdfe:dcba:9876::1/126"
                                                        ],
                                                        "route_address": [
                                                            "0.0.0.0/1",
                                                            "128.0.0.0/1",
                                                            "::/1",
                                                            "8000::/1"
                                                        ],
                                                        "route_exclude_address": [
                                                            "192.168.0.0/16",
                                                            "fc00::/7"
                                                        ]
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                }
            },
            "deprecated": {
                "title": "Deprecated Feature List",
                "1.12.0": {
                    "title": "1.12.0",
                    "features": [
                        {
                            "legacy_dns_server_formats": {
                                "description": "Legacy DNS server formats",
                                "details": "DNS servers are refactored, check [Migration](../migration/#migrate-to-new-dns-servers). Compatibility for old formats will be removed in sing-box 1.14.0."
                            }
                        },
                        {
                            "outbound_dns_rule_item": {
                                "description": "`outbound` DNS rule item",
                                "details": "Legacy `outbound` DNS rules are deprecated and can be replaced by dial fields, check [Migration](../migration/#migrate-outbound-dns-rule-items-to-domain-resolver)."
                            }
                        },
                        {
                            "legacy_ech_fields": {
                                "description": "Legacy ECH fields",
                                "details": "ECH support has been migrated to use stdlib in sing-box 1.12.0, which does not come with support for PQ signature schemes, so `pq_signature_schemes_enabled` has been deprecated and no longer works. Also, `dynamic_record_sizing_disabled` has nothing to do with ECH, was added by mistake, has been deprecated and no longer works. These fields will be removed in sing-box 1.13.0."
                            }
                        }
                    ]
                },
                "1.11.0": {
                    "title": "1.11.0",
                    "features": [
                        {
                            "legacy_special_outbounds": {
                                "description": "Legacy special outbounds",
                                "details": "Legacy special outbounds (`block` / `dns`) are deprecated and can be replaced by rule actions, check [Migration](../migration/#migrate-legacy-special-outbounds-to-rule-actions). Old fields will be removed in sing-box 1.13.0."
                            }
                        },
                        {
                            "legacy_inbound_fields": {
                                "description": "Legacy inbound fields",
                                "details": "Legacy inbound fields （`inbound.<sniff/domain_strategy/...>` are deprecated and can be replaced by rule actions, check [Migration](../migration/#migrate-legacy-inbound-fields-to-rule-actions). Old fields will be removed in sing-box 1.13.0."
                            }
                        },
                        {
                            "destination_override_fields_in_direct_outbound": {
                                "description": "Destination override fields in direct outbound",
                                "details": "Destination override fields (`override_address` / `override_port`) in direct outbound are deprecated and can be replaced by rule actions, check [Migration](../migration/#migrate-destination-override-fields-to-route-options)."
                            }
                        },
                        {
                            "wireguard_outbound": {
                                "description": "WireGuard outbound",
                                "details": "WireGuard outbound is deprecated and can be replaced by endpoint, check [Migration](../migration/#migrate-wireguard-outbound-to-endpoint). Old outbound will be removed in sing-box 1.13.0."
                            }
                        },
                        {
                            "gso_option_in_tun": {
                                "description": "GSO option in TUN",
                                "details": "GSO has no advantages for transparent proxy scenarios, is deprecated and no longer works in TUN. Old fields will be removed in sing-box 1.13.0."
                            }
                        }
                    ]
                },
                "1.10.0": {
                    "title": "1.10.0",
                    "features": [
                        {
                            "tun_address_fields_are_merged": {
                                "description": "TUN address fields are merged",
                                "details": "`inet4_address` and `inet6_address` are merged into `address`, `inet4_route_address` and `inet6_route_address` are merged into `route_address`, `inet4_route_exclude_address` and `inet6_route_exclude_address` are merged into `route_exclude_address`. Old fields will be removed in sing-box 1.12.0."
                            }
                        },
                        {
                            "match_source_rule_items_are_renamed": {
                                "description": "Match source rule items are renamed",
                                "details": "`rule_set_ipcidr_match_source` route and DNS rule items are renamed to `rule_set_ip_cidr_match_source` and will be remove in sing-box 1.11.0."
                            }
                        },
                        {
                            "drop_support_for_go1.18_and_go1.19": {
                                "description": "Drop support for go1.18 and go1.19",
                                "details": "Due to maintenance difficulties, sing-box 1.10.0 requires at least Go 1.20 to compile."
                            }
                        }
                    ]
                },
                "1.8.0": {
                    "title": "1.8.0",
                    "features": [
                        {
                            "cache_file_and_related_features_in_clash_api": {
                                "description": "Cache file and related features in Clash API",
                                "details": "`cache_file` and related features in Clash API is migrated to independent `cache_file` options, check [Migration](/migration/#migrate-cache-file-from-clash-api-to-independent-options)."
                            }
                        },
                        {
                            "geoip": {
                                "description": "GeoIP",
                                "details": "GeoIP is deprecated and will be removed in sing-box 1.12.0. The maxmind GeoIP National Database, as an IP classification database, is not entirely suitable for traffic bypassing, and all existing implementations suffer from high memory usage and difficult management. sing-box 1.8.0 introduces [rule-set](/configuration/rule-set/), which can completely replace GeoIP, check [Migration](/migration/#migrate-geoip-to-rule-sets)."
                            }
                        },
                        {
                            "geosite": {
                                "description": "Geosite",
                                "details": "Geosite is deprecated and will be removed in sing-box 1.12.0. Geosite, the `domain-list-community` project maintained by V2Ray as an early traffic bypassing solution, suffers from a number of problems, including lack of maintenance, inaccurate rules, and difficult management. sing-box 1.8.0 introduces [rule-set](/configuration/rule-set/), which can completely replace Geosite, check [Migration](/migration/#migrate-geosite-to-rule-sets)."
                            }
                        }
                    ]
                },
                "1.6.0": {
                    "title": "1.6.0",
                    "features": [
                        {
                            "shadowsocksr": {
                                "description": "ShadowsocksR",
                                "details": "ShadowsocksR support has never been enabled by default, since the most commonly used proxy sales panel in the illegal industry stopped using this protocol, it does not make sense to continue to maintain it."
                            }
                        },
                        {
                            "proxy_protocol": {
                                "description": "Proxy Protocol",
                                "details": "Proxy Protocol is added by Pull Request, has problems, is only used by the backend of HTTP multiplexers such as nginx, is intrusive, and is meaningless for proxy purposes."
                            }
                        }
                    ]
                }
            },
            "installation": {
                "package_manager": {
                    "title": "Package Manager",
                    "repository_installation": {
                        "title": "Repository Installation",
                        "debian_apt": {
                            "title": "Debian / APT",
                            "command": "sudo curl -fsSL https://sing-box.app/gpg.key -o /etc/apt/keyrings/sagernet.asc\nsudo chmod a+r /etc/apt/keyrings/sagernet.asc\necho \"deb [arch=`dpkg --print-architecture` signed-by=/etc/apt/keyrings/sagernet.asc] https://deb.sagernet.org/ * *\" | sudo tee /etc/apt/sources.list.d/sagernet.list > /dev/null\nsudo apt-get update\nsudo apt-get install sing-box # or sing-box-beta"
                        },
                        "redhat_dnf": {
                            "title": "Redhat / DNF",
                            "command": "sudo dnf -y install dnf-plugins-core\nsudo dnf config-manager --add-repo https://sing-box.app/sing-box.repo\nsudo dnf install sing-box # or sing-box-beta\n(This applies to any distribution that uses `dnf` as the package manager: Fedora, CentOS, even OpenSUSE with DNF installed.)"
                        }
                    },
                    "manual_installation": {
                        "title": "Manual Installation",
                        "debian_deb": {
                            "title": "Debian / DEB",
                            "command": "bash <(curl -fsSL https://sing-box.app/deb-install.sh)"
                        },
                        "redhat_rpm": {
                            "title": "Redhat / RPM",
                            "command": "bash <(curl -fsSL https://sing-box.app/rpm-install.sh)\n(This applies to any distribution that uses `rpm` and `systemd`.  Because of how `rpm` defines dependencies, if it installs, it probably works.)"
                        },
                        "archlinux_pkg": {
                            "title": "Archlinux / PKG",
                            "command": "bash <(curl -fsSL https://sing-box.app/arch-install.sh)"
                        }
                    },
