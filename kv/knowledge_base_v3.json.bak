                        "fields": {
                            "title": "Fields",
                            "enabled": {
                                "title": "enabled",
                                "description": "Enable TLS."
                            },
                            "disable_sni": {
                                "title": "disable_sni",
                                "description": "==Client only== Do not send server name in ClientHello."
                            },
                            "server_name": {
                                "title": "server_name",
                                "description": "Used to verify the hostname on the returned certificates unless insecure is given. It is also included in the client's handshake to support virtual hosting unless it is an IP address."
                            },
                            "insecure": {
                                "title": "insecure",
                                "description": "==Client only== Accepts any server certificate."
                            },
                            "alpn": {
                                "title": "alpn",
                                "description": "List of supported application level protocols, in order of preference. If both peers support ALPN, the selected protocol will be one from this list, and the connection will fail if there is no mutually supported protocol. See [Application-Layer Protocol Negotiation](https://en.wikipedia.org/wiki/Application-Layer_Protocol_Negotiation)."
                            },
                            "min_version": {
                                "title": "min_version",
                                "description": "The minimum TLS version that is acceptable. By default, TLS 1.2 is currently used as the minimum when acting as a client, and TLS 1.0 when acting as a server."
                            },
                            "max_version": {
                                "title": "max_version",
                                "description": "The maximum TLS version that is acceptable. By default, the maximum version is currently TLS 1.3."
                            },
                            "cipher_suites": {
                                "title": "cipher_suites",
                                "description": "A list of enabled TLS 1.0–1.2 cipher suites. The order of the list is ignored. Note that TLS 1.3 cipher suites are not configurable. If empty, a safe default list is used. The default cipher suites might change over time."
                            },
                            "certificate": {
                                "title": "certificate",
                                "description": "The server certificate line array, in PEM format."
                            },
                            "certificate_path": {
                                "title": "certificate_path",
                                "description": "The path to the server certificate, in PEM format.",
                                "note": "Will be automatically reloaded if file modified."
                            },
                            "key": {
                                "title": "key",
                                "description": "==Server only== The server private key line array, in PEM format."
                            },
                            "key_path": {
                                "title": "key_path",
                                "description": "==Server only== The path to the server private key, in PEM format.",
                                "note": "Will be automatically reloaded if file modified."
                            },
                            "custom_tls_support": {
                                "title": "Custom TLS support",
                                "quic_support": {
                                    "title": "QUIC support",
                                    "description": "Only ECH is supported in QUIC."
                                },
                                "utls": {
                                    "title": "utls",
                                    "description": "==Client only== uTLS is a fork of \"crypto/tls\", which provides ClientHello fingerprinting resistance. Available fingerprint values:",
                                    "deprecated_fingerprints": [
                                        "Some legacy chrome fingerprints have been removed and will fallback to chrome: :material-close: chrome_psk :material-close: chrome_psk_shuffle :material-close: chrome_padding_psk_shuffle :material-close: chrome_pq :material-close: chrome_pq_psk"
                                    ],
                                    "available_fingerprints": [
                                        "chrome",
                                        "firefox",
                                        "edge",
                                        "safari",
                                        "360",
                                        "qq",
                                        "ios",
                                        "android",
                                        "random",
                                        "randomized"
                                    ],
                                    "default_value": "Chrome fingerprint will be used if empty."
                                }
                            },
                            "ech_fields": {
                                "title": "ECH Fields",
                                "description": "ECH (Encrypted Client Hello) is a TLS extension that allows a client to encrypt the first part of its ClientHello message. The ECH key and configuration can be generated by `sing-box generate ech-keypair`.",
                                "pq_signature_schemes_enabled": {
                                    "title": "pq_signature_schemes_enabled",
                                    "description": "Enable support for post-quantum peer certificate signature schemes.",
                                    "deprecated": "ECH support has been migrated to use stdlib in sing-box 1.12.0, which does not come with support for PQ signature schemes, so `pq_signature_schemes_enabled` has been deprecated and no longer works."
                                },
                                "dynamic_record_sizing_disabled": {
                                    "title": "dynamic_record_sizing_disabled",
                                    "description": "Disables adaptive sizing of TLS records. When true, the largest possible TLS record size is always used. When false, the size of TLS records may be adjusted in an attempt to improve latency.",
                                    "deprecated": "`dynamic_record_sizing_disabled` has nothing to do with ECH, was added by mistake, has been deprecated and no longer works."
                                },
                                "key": {
                                    "title": "key",
                                    "description": "==Server only== ECH key line array, in PEM format."
                                },
                                "key_path": {
                                    "title": "key_path",
                                    "description": "==Server only== The path to ECH key, in PEM format.",
                                    "note": "Will be automatically reloaded if file modified."
                                },
                                "config": {
                                    "title": "config",
                                    "description": "==Client only== ECH configuration line array, in PEM format. If empty, load from DNS will be attempted."
                                },
                                "config_path": {
                                    "title": "config_path",
                                    "description": "==Client only== The path to ECH configuration, in PEM format. If empty, load from DNS will be attempted."
                                }
                            },
                            "acme_fields": {
                                "title": "ACME Fields",
                                "domain": {
                                    "title": "domain",
                                    "description": "List of domain. ACME will be disabled if empty."
                                },
                                "data_directory": {
                                    "title": "data_directory",
                                    "description": "The directory to store ACME data. `$XDG_DATA_HOME/certmagic|$HOME/.local/share/certmagic` will be used if empty."
                                },
                                "default_server_name": {
                                    "title": "default_server_name",
                                    "description": "Server name to use when choosing a certificate if the ClientHello's ServerName field is empty."
                                },
                                "email": {
                                    "title": "email",
                                    "description": "The email address to use when creating or selecting an existing ACME server account"
                                },
                                "provider": {
                                    "title": "provider",
                                    "description": "The ACME CA provider to use.",
                                    "table": {
                                        "headers": [
                                            "Value",
                                            "Provider"
                                        ],
                                        "rows": [
                                            {
                                                "value": "`letsencrypt (default)`",
                                                "provider": "Let's Encrypt"
                                            },
                                            {
                                                "value": "`zerossl`",
                                                "provider": "ZeroSSL"
                                            },
                                            {
                                                "value": "`https://...`",
                                                "provider": "Custom"
                                            }
                                        ]
                                    }
                                },
                                "disable_http_challenge": {
                                    "title": "disable_http_challenge",
                                    "description": "Disable all HTTP challenges."
                                },
                                "disable_tls_alpn_challenge": {
                                    "title": "disable_tls_alpn_challenge",
                                    "description": "Disable all TLS-ALPN challenges"
                                },
                                "alternative_http_port": {
                                    "title": "alternative_http_port",
                                    "description": "The alternate port to use for the ACME HTTP challenge; if non-empty, this port will be used instead of 80 to spin up a listener for the HTTP challenge."
                                },
                                "alternative_tls_port": {
                                    "title": "alternative_tls_port",
                                    "description": "The alternate port to use for the ACME TLS-ALPN challenge; the system must forward 443 to this port for challenge to succeed."
                                },
                                "external_account": {
                                    "title": "external_account",
                                    "description": "EAB (External Account Binding) contains information necessary to bind or map an ACME account to some other account known by the CA. External account bindings are \"used to associate an ACME account with an existing account in a non-ACME system, such as a CA customer database. To enable ACME account binding, the CA operating the ACME server needs to provide the ACME client with a MAC key and a key identifier, using some mechanism outside of ACME. §7.3.4"
                                },
                                "external_account_key_id": {
                                    "title": "external_account.key_id",
                                    "description": "The key identifier."
                                },
                                "external_account_mac_key": {
                                    "title": "external_account.mac_key",
                                    "description": "The MAC key."
                                },
                                "dns01_challenge": {
                                    "title": "dns01_challenge",
                                    "description": "ACME DNS01 challenge field. If configured, other challenge methods will be disabled. See [DNS01 Challenge Fields](/configuration/shared/dns01_challenge/) for details."
                                }
                            },
                            "reality_fields": {
                                "title": "Reality Fields",
                                "handshake": {
                                    "title": "handshake",
                                    "description": "==Server only== ==Required== Handshake server address and [Dial Fields](/configuration/shared/dial/)."
                                },
                                "private_key": {
                                    "title": "private_key",
                                    "description": "==Server only== ==Required== Private key, generated by `sing-box generate reality-keypair`."
                                },
                                "public_key": {
                                    "title": "public_key",
                                    "description": "==Client only== ==Required== Public key, generated by `sing-box generate reality-keypair`."
                                },
                                "short_id": {
                                    "title": "short_id",
                                    "description": "==Required== A hexadecimal string with zero to eight digits."
                                },
                                "max_time_difference": {
                                    "title": "max_time_difference",
                                    "description": "==Server only== The maximum time difference between the server and the client. Check disabled if empty."
                                }
                            }
                        }
                    },
                    "dns01_challenge": {
                        "title": "DNS01 Challenge Fields",
                        "structure": {
                            "title": "Structure",
