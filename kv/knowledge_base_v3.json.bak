                                "title": "users",
                                "description": "SOCKS and HTTP users. No authentication required if empty."
                            },
                            "set_system_proxy": {
                                "title": "set_system_proxy",
                                "description": "Automatically set system proxy configuration when start and clean up when stop.",
                                "note": "Only supported on Linux, Android, Windows, and macOS.",
                                "warning": "To work on Android and Apple platforms without privileges, use tun.platform.http_proxy instead."
                            }
