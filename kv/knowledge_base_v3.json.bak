                        "address_filter_fields": {
                            "title": "Address Filter Fields",
                            "description": "Only takes effect for address requests (A/AAAA/HTTPS). When the query results do not match the address filtering rule items, the current rule will be skipped.",
                            "note": "`ip_cidr` items in included rule-sets also takes effect as an address filtering field.",
                            "experimental_note": "Enable `experimental.cache_file.store_rdrc` to cache results.",
                            "geoip": {
                                "title": "geoip",
                                "description": "Match GeoIP with query response.",
                                "deprecated": "GeoIP is deprecated in sing-box 1.8.0 and removed in sing-box 1.12.0, check [Migration](/migration/#migrate-geoip-to-rule-sets)."
                            },
                            "ip_cidr": {
                                "title": "ip_cidr",
                                "description": "Match IP CIDR with query response.",
                                "since": "Since sing-box 1.9.0"
                            },
                            "ip_is_private": {
                                "title": "ip_is_private",
                                "description": "Match private IP with query response.",
                                "since": "Since sing-box 1.9.0"
                            },
                            "rule_set_ip_cidr_accept_empty": {
                                "title": "rule_set_ip_cidr_accept_empty",
