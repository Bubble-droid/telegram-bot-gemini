                "rule-set": {
                    "main": {
                        "title": "rule-set",
                        "description": "Defines a set of rules for routing or filtering traffic.",
                        "since": "Since sing-box 1.8.0",
                        "structure": {
                            "title": "Structure",
                            "inline": {
                                "title": "Inline",
                                "description": "Defines a rule-set inline.",
                                "since": "Since sing-box 1.10.0",
                                "json": {
                                    "type": "inline",
                                    "tag": "",
                                    "rules": []
                                }
                            },
                            "local_file": {
                                "title": "Local File",
                                "description": "Defines a rule-set from a local file.",
                                "json": {
                                    "type": "local",
                                    "tag": "",
                                    "format": "source",
                                    "path": ""
                                }
                            },
                            "remote_file": {
                                "title": "Remote File",
                                "description": "Defines a rule-set from a remote file.",
                                "info": "Remote rule-set will be cached if `experimental.cache_file.enabled`.",
                                "json": {
                                    "type": "remote",
                                    "tag": "",
                                    "format": "source",
                                    "url": "",
                                    "download_detour": "",
                                    "update_interval": ""
                                }
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "type": {
                                "title": "type",
                                "description": "Type of rule-set, `local` or `remote`.",
                                "required": true
                            },
                            "tag": {
                                "title": "tag",
                                "description": "Tag of rule-set.",
                                "required": true
                            }
                        },
                        "inline_fields": {
                            "title": "Inline Fields",
                            "rules": {
                                "title": "rules",
                                "description": "List of [Headless Rule](./headless-rule/)."
                            },
                            "since": "Since sing-box 1.10.0"
                        },
                        "local_or_remote_fields": {
                            "title": "Local or Remote Fields",
                            "format": {
                                "title": "format",
                                "description": "Format of rule-set file, `source` or `binary`.",
                                "required": true
                            }
                        },
                        "local_fields": {
                            "title": "Local Fields",
                            "path": {
                                "title": "path",
                                "description": "File path of rule-set.",
                                "required": true,
                                "note": "Will be automatically reloaded if file modified since sing-box 1.10.0."
                            }
                        },
                        "remote_fields": {
                            "title": "Remote Fields",
                            "url": {
                                "title": "url",
                                "description": "Download URL of rule-set.",
                                "required": true
                            },
                            "download_detour": {
                                "title": "download_detour",
                                "description": "Tag of the outbound to download rule-set. Default outbound will be used if empty."
                            },
                            "update_interval": {
                                "title": "update_interval",
                                "description": "Update interval of rule-set. `1d` will be used if empty."
                            }
                        }
                    },
                    "source-format": {
                        "title": "Source Format",
                        "description": "Defines the format of the rule-set source file.",
                        "changes": {
                            "sing_box_1.11.0": {
                                "title": "Changes in sing-box 1.11.0",
                                "features": [
                                    "version `3`"
                                ]
                            },
                            "sing_box_1.10.0": {
                                "title": "Changes in sing-box 1.10.0",
                                "features": [
                                    "version `2`"
                                ]
                            },
                            "sing_box_1.8.0": {
                                "title": "Since sing-box 1.8.0"
                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "version": 3,
                                "rules": []
                            }
                        },
                        "compile": {
                            "title": "Compile",
                            "description": "Use `sing-box rule-set compile [--output <file-name>.srs] <file-name>.json` to compile source to binary rule-set."
                        },
                        "fields": {
                            "title": "Fields",
                            "version": {
                                "title": "version",
                                "description": "Version of rule-set.",
                                "required": true,
                                "versions": [
                                    {
                                        "version": "1",
                                        "description": "sing-box 1.8.0: Initial rule-set version."
                                    },
                                    {
                                        "version": "2",
                                        "description": "sing-box 1.10.0: Optimized memory usages of `domain_suffix` rules in binary rule-sets."
                                    },
                                    {
                                        "version": "3",
                                        "description": "sing-box 1.11.0: Added `network_type`, `network_is_expensive` and `network_is_constrainted` rule items."
                                    }
                                ]
                            },
                            "rules": {
                                "title": "rules",
                                "description": "List of [Headless Rule](../headless-rule/)."
                            }
                        }
                    },
                    "headless-rule": {
                        "title": "Headless Rule",
                        "description": "Defines a rule for traffic matching within a rule-set.",
                        "changes": {
                            "sing_box_1.11.0": {
                                "title": "Changes in sing-box 1.11.0",
                                "features": [
                                    "[network_type](#network_type)",
                                    "[network_is_expensive](#network_is_expensive)",
                                    "[network_is_constrained](#network_is_constrained)"
                                ]
                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "rules": [
                                    {
                                        "query_type": [
                                            "A",
                                            "HTTPS",
                                            32768
                                        ],
                                        "network": [
                                            "tcp"
                                        ],
                                        "domain": [
                                            "test.com"
                                        ],
                                        "domain_suffix": [
                                            ".cn"
                                        ],
                                        "domain_keyword": [
                                            "test"
                                        ],
                                        "domain_regex": [
                                            "^stun\\..+"
                                        ],
                                        "source_ip_cidr": [
                                            "10.0.0.0/24",
                                            "192.168.0.1"
                                        ],
                                        "ip_cidr": [
                                            "10.0.0.0/24",
                                            "192.168.0.1"
                                        ],
                                        "source_port": [
                                            12345
                                        ],
                                        "source_port_range": [
                                            "1000:2000",
                                            ":3000",
                                            "4000:"
                                        ],
                                        "port": [
                                            80,
                                            443
                                        ],
                                        "port_range": [
                                            "1000:2000",
                                            ":3000",
                                            "4000:"
                                        ],
                                        "process_name": [
                                            "curl"
                                        ],
                                        "process_path": [
                                            "/usr/bin/curl"
                                        ],
                                        "process_path_regex": [
                                            "^/usr/bin/.+"
                                        ],
                                        "package_name": [
                                            "com.termux"
                                        ],
                                        "network_type": [
                                            "wifi"
                                        ],
                                        "network_is_expensive": false,
                                        "network_is_constrained": false,
                                        "wifi_ssid": [
                                            "My WIFI"
                                        ],
                                        "wifi_bssid": [
                                            "00:00:00:00:00:00"
                                        ],
                                        "invert": false
                                    },
                                    {
                                        "type": "logical",
                                        "mode": "and",
                                        "rules": [],
                                        "invert": false
                                    }
                                ]
                            },
                            "note": "You can ignore the JSON Array [] tag when the content is only one item"
                        },
                        "default_fields": {
                            "title": "Default Fields",
                            "description": "The default rule uses the following matching logic:\n(`domain` || `domain_suffix` || `domain_keyword` || `domain_regex` || `ip_cidr`) &&\n(`port` || `port_range`) &&\n(`source_port` || `source_port_range`) &&\n`other fields`"
                        },
                        "fields": {
                            "title": "Fields",
                            "query_type": {
                                "title": "query_type",
                                "description": "DNS query type. Values can be integers or type name strings."
                            },
                            "network": {
                                "title": "network",
                                "description": "`tcp` or `udp`."
                            },
                            "domain": {
                                "title": "domain",
                                "description": "Match full domain."
                            },
                            "domain_suffix": {
                                "title": "domain_suffix",
                                "description": "Match domain suffix."
                            },
                            "domain_keyword": {
                                "title": "domain_keyword",
                                "description": "Match domain using keyword."
                            },
                            "domain_regex": {
                                "title": "domain_regex",
                                "description": "Match domain using regular expression."
                            },
                            "source_ip_cidr": {
                                "title": "source_ip_cidr",
                                "description": "Match source IP CIDR."
                            },
                            "ip_cidr": {
                                "title": "ip_cidr",
                                "description": "Match IP CIDR.",
                                "info": "`ip_cidr` is an alias for `source_ip_cidr` when `rule_set_ipcidr_match_source` enabled in route/DNS rules."
                            },
                            "source_port": {
                                "title": "source_port",
                                "description": "Match source port."
                            },
                            "source_port_range": {
                                "title": "source_port_range",
                                "description": "Match source port range."
                            },
                            "port": {
                                "title": "port",
                                "description": "Match port."
                            },
                            "port_range": {
                                "title": "port_range",
                                "description": "Match port range."
                            },
                            "process_name": {
                                "title": "process_name",
                                "description": "Match process name.",
                                "note": "Only supported on Linux, Windows, and macOS."
                            },
                            "process_path": {
                                "title": "process_path",
                                "description": "Match process path.",
                                "note": "Only supported on Linux, Windows, and macOS."
                            },
                            "process_path_regex": {
                                "title": "process_path_regex",
                                "description": "Match process path using regular expression.",
                                "since": "Since sing-box 1.10.0",
                                "note": "Only supported on Linux, Windows, and macOS."
                            },
                            "package_name": {
                                "title": "package_name",
                                "description": "Match android package name."
                            },
                            "network_type": {
                                "title": "network_type",
                                "description": "Match network type.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms. Available values: `wifi`, `cellular`, `ethernet` and `other`."
                            },
                            "network_is_expensive": {
                                "title": "network_is_expensive",
                                "description": "Match if network is considered Metered (on Android) or considered expensive, such as Cellular or a Personal Hotspot (on Apple platforms).",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms."
                            },
                            "network_is_constrained": {
                                "title": "network_is_constrained",
                                "description": "Match if network is in Low Data Mode.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Apple platforms."
                            },
                            "wifi_ssid": {
                                "title": "wifi_ssid",
                                "description": "Match WiFi SSID.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms."
                            },
                            "wifi_bssid": {
                                "title": "wifi_bssid",
                                "description": "Match WiFi BSSID.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Only supported in graphical clients on Android and Apple platforms."
                            },
                            "invert": {
                                "title": "invert",
                                "description": "Invert match result."
                            }
                        },
                        "logical_fields": {
                            "title": "Logical Fields",
                            "type": {
                                "title": "type",
                                "description": "`logical`"
                            },
                            "mode": {
                                "title": "mode",
                                "description": "==Required== `and` or `or`"
                            },
                            "rules": {
                                "title": "rules",
                                "description": "==Required== Included rules."
                            }
                        }
                    },
                    "adguard": {
                        "title": "AdGuard",
                        "description": "sing-box supports some rule-set formats from other projects which cannot be fully translated to sing-box, currently only AdGuard DNS Filter.",
                        "since": "Since sing-box 1.10.0",
                        "structure": {
                            "title": "Structure",
                            "description": "These formats are not directly supported as source formats, instead you need to convert them to binary rule-set."
                        },
                        "convert": {
                            "title": "Convert",
                            "description": "Use `sing-box rule-set convert --type adguard [--output <file-name>.srs] <file-name>.txt` to convert to binary rule-set."
                        },
                        "performance": {
                            "title": "Performance",
                            "description": "AdGuard keeps all rules in memory and matches them sequentially, while sing-box chooses high performance and smaller memory usage. As a trade-off, you cannot know which rule item is matched."
                        },
                        "compatibility": {
                            "title": "Compatibility",
                            "description": "Almost all rules in [AdGuardSDNSFilter](https://github.com/AdguardTeam/AdGuardSDNSFilter) and rules in rule-sets listed in [adguard-filter-list](https://github.com/ppfeufer/adguard-filter-list) are supported."
                        },
                        "supported_formats": {
                            "title": "Supported formats",
                            "adguard_filter": {
                                "title": "AdGuard Filter",
                                "basic_rule_syntax": {
                                    "title": "Basic rule syntax",
                                    "table": {
                                        "headers": [
                                            "Syntax",
                                            "Supported"
                                        ],
                                        "rows": [
                                            {
                                                "syntax": "`@@`",
                                                "supported": ":material-check:"
                                            },
                                            {
                                                "syntax": "`\\|\\|`",
                                                "supported": ":material-check:"
                                            },
                                            {
                                                "syntax": "`\\|`",
                                                "supported": ":material-check:"
                                            },
                                            {
                                                "syntax": "`^`",
                                                "supported": ":material-check:"
                                            },
                                            {
                                                "syntax": "`*`",
                                                "supported": ":material-check:"
                                            }
                                        ]
                                    }
                                },
                                "host_syntax": {
                                    "title": "Host syntax",
                                    "table": {
                                        "headers": [
                                            "Syntax",
                                            "Example",
                                            "Supported"
                                        ],
                                        "rows": [
                                            {
                                                "syntax": "Scheme",
                                                "example": "`https://`",
                                                "supported": ":material-alert: Ignored"
                                            },
                                            {
                                                "syntax": "Domain Host",
                                                "example": "`example.org`",
                                                "supported": ":material-check:"
                                            },
                                            {
                                                "syntax": "IP Host",
                                                "example": "`1.1.1.1`, `10.0.0.`",
                                                "supported": ":material-close:"
                                            },
                                            {
                                                "syntax": "Regexp",
                                                "example": "`/regexp/`",
                                                "supported": ":material-check:"
                                            },
                                            {
                                                "syntax": "Port",
                                                "example": "`example.org:80`",
                                                "supported": ":material-close:"
                                            },
                                            {
                                                "syntax": "Path",
                                                "example": "`example.org/path/ad.js`",
                                                "supported": ":material-close:"
                                            }
                                        ]
                                    }
                                },
                                "modifier_syntax": {
                                    "title": "Modifier syntax",
                                    "table": {
                                        "headers": [
                                            "Modifier",
                                            "Supported"
                                        ],
                                        "rows": [
                                            {
                                                "modifier": "`$important`",
                                                "supported": ":material-check:"
                                            },
                                            {
                                                "modifier": "`$dnsrewrite=0.0.0.0`",
                                                "supported": ":material-alert: Ignored"
                                            },
                                            {
                                                "modifier": "Any other modifiers",
                                                "supported": ":material-close:"
                                            }
                                        ]
                                    }
                                }
                            },
                            "hosts": {
                                "title": "Hosts",
                                "description": "Only items with `0.0.0.0` IP addresses will be accepted."
                            },
                            "simple": {
                                "title": "Simple",
                                "description": "When all rule lines are valid domains, they are treated as simple line-by-line domain rules which, like hosts, only match the exact same domain."
                            }
                        }
                    }
                },
