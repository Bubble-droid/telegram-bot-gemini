                                "title": "padding_scheme",
                                "description": "AnyTLS padding scheme line array. Default padding scheme:",
                                "default_padding_scheme": "stop=8\n0=34-120\n1=100-400\n2=400-500,c,500-1000,c,400-500,c,500-1000,c,500-1000,c,400-500\n3=500-1000\n4=500-1000\n5=500-1000\n6=500-1000\n7=500-1000"
