        "hysteria_docs": {
            "port_hopping": {
                "title": "Port Hopping",
                "description": "Technique to bypass ISP blocking or throttling of persistent UDP connections in China.",
                "client": {
                    "title": "Client",
                    "description": "The Hysteria client supports a special multi-port address format:",
                    "address_format": {
                        "code": "example.com:1234,5678,9012 # (1)!\nexample.com:20000-50000 # (2)!\nexample.com:1234,5000-6000,7044,8000-9000 # (3)!",
                        "notes": [
                            "Multiple individual ports.",
                            "A range of ports.",
                            "A combination of both."
                        ],
                        "limitation": "There is no limit to the number of ports you can specify.",
                        "hop_interval_control": "The client will randomly select one of the specified ports for the initial connection and will periodically switch to a different port. The option for controlling the interval is `hopInterval` in the `transport` section:",
                        "code_example": "transport:\n  udp:\n    hopInterval: 30s # (1)!",
                        "hop_interval_note": "30s is the default. It must be at least 5s."
                    }
                },
                "server": {
                    "title": "Server",
                    "description": "The Hysteria server does not have built-in support for listening on multiple ports, so you cannot use the above format as a listening address on the server side. **We recommend using iptables or nftables DNAT to forward the ports to the server's listening port.**",
                    "iptables": {
                        "title": "iptables",
                        "code": "# IPv4\niptables -t nat -A PREROUTING -i eth0 -p udp --dport 20000:50000 -j REDIRECT --to-ports 443\n# IPv6\nip6tables -t nat -A PREROUTING -i eth0 -p udp --dport 20000:50000 -j REDIRECT --to-ports 443"
                    },
                    "nftables": {
                        "title": "nftables",
                        "code": "define INGRESS_INTERFACE=\"eth0\"\ndefine PORT_RANGE=20000-50000\ndefine HYSTERIA_SERVER_PORT=443\n\ntable inet hysteria_porthopping {\n  chain prerouting {\n    type nat hook prerouting priority dstnat; policy accept;\n    iifname $INGRESS_INTERFACE udp dport $PORT_RANGE counter redirect to :$HYSTERIA_SERVER_PORT\n  }\n}",
                        "example_note": "In this example, the server listens on port 443, but the client can connect to any port in the range 20000-50000."
                    }
                }
            }
        }
    }
}
