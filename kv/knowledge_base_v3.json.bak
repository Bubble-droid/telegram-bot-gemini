                    "tun": {
                        "title": "Tun",
                        "description": "Configuration for a TUN inbound.",
                        "since": "Only supported on Linux, Windows and macOS.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "tun",
                                "tag": "tun-in",
                                "interface_name": "tun0",
                                "address": [
                                    "172.18.0.1/30",
                                    "fdfe:dcba:9876::1/126"
                                ],
                                "mtu": 9000,
                                "auto_route": true,
                                "iproute2_table_index": 2022,
                                "iproute2_rule_index": 9000,
                                "auto_redirect": false,
                                "auto_redirect_input_mark": "0x2023",
                                "auto_redirect_output_mark": "0x2024",
                                "strict_route": true,
                                "route_address": [
                                    "0.0.0.0/1",
                                    "128.0.0.0/1",
                                    "::/1",
                                    "8000::/1"
                                ],
                                "route_exclude_address": [
                                    "192.168.0.0/16",
                                    "fc00::/7"
                                ],
                                "route_address_set": [
                                    "geoip-cloudflare"
                                ],
                                "route_exclude_address_set": [
                                    "geoip-cn"
                                ],
                                "endpoint_independent_nat": false,
                                "udp_timeout": "5m",
                                "stack": "system",
                                "include_interface": [
                                    "lan0"
                                ],
                                "exclude_interface": [
                                    "lan1"
                                ],
                                "include_uid": [
                                    0
                                ],
                                "include_uid_range": [
                                    "1000:99999"
                                ],
                                "exclude_uid": [
                                    1000
                                ],
                                "exclude_uid_range": [
                                    "1000:99999"
                                ],
                                "include_android_user": [
                                    0,
                                    10
                                ],
                                "include_package": [
                                    "com.android.chrome"
                                ],
                                "exclude_package": [
                                    "com.android.captiveportallogin"
                                ],
                                "platform": {
                                    "http_proxy": {
                                        "enabled": false,
                                        "server": "127.0.0.1",
                                        "server_port": 8080,
                                        "bypass_domain": [],
                                        "match_domain": []
                                    }
                                }
                            }
                        },
                        "note": "If tun is running in non-privileged mode, addresses and MTU will not be configured automatically, please make sure the settings are accurate.",
                        "fields": {
                            "title": "Tun Fields",
                            "interface_name": {
                                "title": "interface_name",
                                "description": "Virtual device name, automatically selected if empty."
                            },
                            "address": {
                                "title": "address",
                                "description": "IPv4 and IPv6 prefix for the tun interface.",
                                "since": "Since sing-box 1.10.0",
                                "required": true
                            },
                            "mtu": {
                                "title": "mtu",
                                "description": "The maximum transmission unit."
                            },
                            "gso": {
                                "title": "gso",
                                "description": "Enable generic segmentation offload.",
                                "since": "Since sing-box 1.8.0",
                                "deprecated": "Deprecated in sing-box 1.11.0 and has been removed."
                            },
                            "auto_route": {
                                "title": "auto_route",
                                "description": "Set the default route to the Tun. To avoid traffic loopback, set `route.auto_detect_interface` or `route.default_interface` or `outbound.bind_interface`"
                            },
                            "iproute2_table_index": {
                                "title": "iproute2_table_index",
                                "description": "Linux iproute2 table index generated by `auto_route`. `2022` is used by default.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "iproute2_rule_index": {
                                "title": "iproute2_rule_index",
                                "description": "Linux iproute2 rule start index generated by `auto_route`. `9000` is used by default.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "auto_redirect": {
                                "title": "auto_redirect",
                                "description": "Automatically configure iptables/nftables to redirect connections.",
                                "since": "Since sing-box 1.10.0",
                                "note": "*In Android*: Only local IPv4 connections are forwarded. To share your VPN connection over hotspot or repeater, use [VPNHotspot](https://github.com/Mygod/VPNHotspot). *In Linux*: `auto_route` with `auto_redirect` works as expected on routers **without intervention**."
                            },
                            "auto_redirect_input_mark": {
                                "title": "auto_redirect_input_mark",
                                "description": "Connection input mark used by `route[_exclude]_address_set` with `auto_redirect`. `0x2023` is used by default.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "auto_redirect_output_mark": {
                                "title": "auto_redirect_output_mark",
                                "description": "Connection input mark used by `route[_exclude]_address_set` with `auto_redirect`. `0x2024` is used by default.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "strict_route": {
                                "title": "strict_route",
                                "description": "Enforce strict routing rules when `auto_route` is enabled: *In Linux*: * Let unsupported network unreachable * Make ICMP traffic route to tun instead of upstream interfaces * Route all connections to tun. It prevents IP address leaks and makes DNS hijacking work on Android. *In Windows*: * Add firewall rules to prevent DNS leak caused by Windows' [ordinary multihomed DNS resolution behavior](https://learn.microsoft.com/en-us/previous-versions/windows/it-pro/windows-server-2008-R2-and-2008/dd197552%28v%3Dws.10%29) It may prevent some applications (such as VirtualBox) from working properly in certain situations."
                            },
                            "route_address": {
                                "title": "route_address",
                                "description": "Use custom routes instead of default when `auto_route` is enabled.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "route_exclude_address": {
                                "title": "route_exclude_address",
                                "description": "Exclude custom routes when `auto_route` is enabled.",
                                "since": "Since sing-box 1.10.0"
                            },
                            "route_address_set": {
                                "title": "route_address_set",
                                "description": "Add the destination IP CIDR rules in the specified rule-sets to routes, equivalent to adding to `route_address`. Unmatched traffic will bypass the sing-box routes. Note that it **doesn't work on the Android graphical client** due to the Android VpnService not being able to handle a large number of routes (DeadSystemException), but otherwise it works fine on all command line clients and Apple platforms.",
                                "since": "Since sing-box 1.11.0",
                                "with_auto_redirect": "With `auto_redirect` enabled: Add the destination IP CIDR rules in the specified rule-sets to the firewall.",
                                "without_auto_redirect": "Without `auto_redirect` enabled: Add the destination IP CIDR rules in the specified rule-sets to routes, equivalent to adding to `route_address`. Unmatched traffic will bypass the sing-box routes."
                            },
                            "route_exclude_address_set": {
                                "title": "route_exclude_address_set",
                                "description": "Add the destination IP CIDR rules in the specified rule-sets to routes, equivalent to adding to `route_exclude_address`. Matched traffic will bypass the sing-box routes. Note that it **doesn't work on the Android graphical client** due to the Android VpnService not being able to handle a large number of routes (DeadSystemException), but otherwise it works fine on all command line clients and Apple platforms.",
                                "since": "Since sing-box 1.11.0",
                                "with_auto_redirect": "With `auto_redirect` enabled: Add the destination IP CIDR rules in the specified rule-sets to the firewall.",
                                "without_auto_redirect": "Without `auto_redirect` enabled: Add the destination IP CIDR rules in the specified rule-sets to routes, equivalent to adding to `route_exclude_address`. Matched traffic will bypass the sing-box routes."
                            },
                            "endpoint_independent_nat": {
                                "title": "endpoint_independent_nat",
                                "description": "Enable endpoint-independent NAT. Performance may degrade slightly, so it is not recommended to enable on when it is not needed.",
                                "info": "This item is only available on the gvisor stack, other stacks are endpoint-independent NAT by default."
                            },
                            "udp_timeout": {
                                "title": "udp_timeout",
                                "description": "UDP NAT expiration time. `5m` will be used by default."
                            },
                            "stack": {
                                "title": "stack",
                                "description": "TCP/IP stack.",
                                "since": "Since sing-box 1.8.0",
                                "available_values": [
                                    "`system`: Perform L3 to L4 translation using the system network stack",
                                    "`gvisor`: Perform L3 to L4 translation using [gVisor](https://github.com/google/gvisor)'s virtual network stack",
                                    "`mixed`: Mixed `system` TCP stack with `gvisor` UDP stack"
                                ],
                                "default_note": "Defaults to the `mixed` stack if the gVisor build tag is enabled, otherwise defaults to the `system` stack.",
                                "deprecated_note": "The legacy LWIP stack has been deprecated and removed."
                            },
                            "include_interface": {
                                "title": "include_interface",
                                "description": "Limit interfaces in route. Not limited by default.",
                                "note": "Interface rules are only supported on Linux and require auto_route. Conflict with `exclude_interface`."
                            },
                            "exclude_interface": {
                                "title": "exclude_interface",
                                "description": "Exclude interfaces in route.",
                                "note": "When `strict_route` enabled, return traffic to excluded interfaces will not be automatically excluded, so add them as well (example: `br-lan` and `pppoe-wan`). Conflict with `include_interface`."
                            },
                            "include_uid": {
                                "title": "include_uid",
                                "description": "Limit users in route. Not limited by default.",
                                "note": "UID rules are only supported on Linux and require auto_route."
                            },
                            "include_uid_range": {
                                "title": "include_uid_range",
                                "description": "Limit users in route, but in range."
                            },
                            "exclude_uid": {
                                "title": "exclude_uid",
                                "description": "Exclude users in route."
                            },
                            "exclude_uid_range": {
                                "title": "exclude_uid_range",
                                "description": "Exclude users in route, but in range."
                            },
                            "include_android_user": {
                                "title": "include_android_user",
                                "description": "Limit android users in route.",
                                "note": "Android user and package rules are only supported on Android and require auto_route.",
                                "table": {
                                    "headers": [
                                        "Common user",
                                        "ID"
                                    ],
                                    "rows": [
                                        {
                                            "common_user": "Main",
                                            "id": "0"
                                        },
                                        {
                                            "common_user": "Work Profile",
                                            "id": "10"
                                        }
                                    ]
                                }
                            },
                            "include_package": {
                                "title": "include_package",
                                "description": "Limit android packages in route."
                            },
                            "exclude_package": {
                                "title": "exclude_package",
                                "description": "Exclude android packages in route."
                            },
                            "platform": {
                                "title": "platform",
                                "description": "Platform-specific settings, provided by client applications.",
                                "http_proxy": {
                                    "title": "platform.http_proxy",
                                    "description": "System HTTP proxy settings.",
                                    "fields": {
                                        "enabled": {
                                            "title": "platform.http_proxy.enabled",
                                            "description": "Enable system HTTP proxy."
                                        },
                                        "server": {
                                            "title": "platform.http_proxy.server",
                                            "description": "==Required== HTTP proxy server address."
                                        },
                                        "server_port": {
                                            "title": "platform.http_proxy.server_port",
                                            "description": "==Required== HTTP proxy server port."
                                        },
                                        "bypass_domain": {
                                            "title": "platform.http_proxy.bypass_domain",
                                            "description": "Hostnames that bypass the HTTP proxy.",
                                            "note": "On Apple platforms, `bypass_domain` items matches hostname **suffixes**."
                                        },
                                        "match_domain": {
                                            "title": "platform.http_proxy.match_domain",
                                            "description": "Hostnames that use the HTTP proxy.",
                                            "note": "Only supported in graphical clients on Apple platforms."
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "redirect": {
                        "title": "Redirect",
                        "description": "Configuration for a redirect inbound. Only supported on Linux and macOS.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "redirect",
