                "general": {
                    "title": "General",
                    "description": "Describes and explains the functions implemented uniformly by sing-box graphical clients.",
                    "profile": {
                        "title": "Profile",
                        "description": "Profile describes a sing-box configuration file and its state.",
                        "local": {
                            "title": "Local",
                            "description": "Local Profile represents a local sing-box configuration with minimal state. The graphical client must provide an editor to modify configuration content"
                        },
                        "icloud": {
                            "title": "iCloud (on iOS and macOS)",
                            "description": "iCloud Profile represents a remote sing-box configuration with iCloud as the update source. The configuration file is stored in the sing-box folder under iCloud. The graphical client must provide an editor to modify configuration content"
                        },
                        "remote": {
                            "title": "Remote",
                            "description": "Remote Profile represents a remote sing-box configuration with a URL as the update source. The graphical client should provide a configuration content viewer. The graphical client must implement automatic profile update (default interval is 60 minutes) and HTTP Basic authorization.",
                            "url_scheme": "At the same time, the graphical client must provide support for importing remote profiles through a specific URL Scheme. The URL is defined as follows:",
                            "url_example": "sing-box://import-remote-profile?url=urlEncodedURL#urlEncodedName"
                        }
                    },
                    "dashboard": {
                        "title": "Dashboard",
                        "description": "While the sing-box service is running, the graphical client should provide a Dashboard interface to manage the service.",
                        "status": {
                            "title": "Status",
                            "description": "Dashboard should display status information such as memory, connection, and traffic."
                        },
                        "mode": {
                            "title": "Mode",
                            "description": "Dashboard should provide a Mode selector for switching when the configuration uses at least two `clash_mode` values."
                        },
                        "groups": {
                            "title": "Groups",
                            "description": "When the configuration includes group outbounds (specifically, Selector or URLTest), the dashboard should provide a Group selector for status display or switching."
                        }
                    },
                    "chore": {
                        "title": "Chore",
                        "description": "Graphical clients should provide a Core region:",
                        "core_region": [
                            "Display the current sing-box version",
                            "Provides a button to clean the working directory",
                            "Provides a memory limiter switch"
                        ]
                    }
                },
                "privacy": {
                    "title": "Privacy policy",
                    "description": "sing-box and official graphics clients do not collect or share personal data, and the data generated by the software is always on your device.",
                    "android": {
                        "description": "If your configuration contains `wifi_ssid` or `wifi_bssid` routing rules, sing-box uses the location permission in the background to get information about the connected Wi-Fi network to make them work."
                    }
                }
            },
            "manual": {
                "proxy": {
                    "server": {
                        "title": "Server",
                        "description": "To use sing-box as a proxy protocol server, you pretty much only need to configure the inbound for that protocol.",
                        "note": "The Proxy Protocol menu below contains descriptions and configuration examples of recommended protocols for bypassing GFW."
                    },
                    "client": {
                        "title": "Client",
                        "introduction": {
                            "title": ":material-ray-start: Introduction",
                            "description": "For a long time, the modern usage and principles of proxy clients for graphical operating systems have not been clearly described. However, we can categorize them into three types: system proxy, firewall redirection, and virtual interface.",
                            "types": [
                                {
                                    "name": "system proxy",
                                    "description": "Almost all graphical environments support system-level proxies, which are essentially ordinary HTTP proxies that only support TCP.",
                                    "table": {
                                        "headers": [
                                            "Operating System / Desktop Environment",
                                            "System Proxy",
                                            "Application Support"
                                        ],
                                        "rows": [
                                            {
                                                "os": "Windows",
                                                "system_proxy": ":material-check:",
                                                "application_support": ":material-check:"
                                            },
                                            {
                                                "os": "macOS",
                                                "system_proxy": ":material-check:",
                                                "application_support": ":material-check:"
                                            },
                                            {
                                                "os": "GNOME/KDE",
                                                "system_proxy": ":material-check:",
                                                "application_support": ":material-check:"
                                            },
                                            {
                                                "os": "Android",
                                                "system_proxy": "ROOT or adb (permission) is required",
                                                "application_support": ":material-check:"
                                            },
                                            {
                                                "os": "Android/iOS (with sing-box graphical client)",
                                                "system_proxy": "via `tun.platform.http_proxy`",
                                                "application_support": ":material-check:"
                                            }
                                        ]
                                    },
                                    "shortcomings": "As one of the most well-known proxy methods, it has many shortcomings: many TCP clients that are not based on HTTP do not check and use the system proxy. Moreover, UDP and ICMP traffics bypass the proxy.",
                                    "diagram": {
                                        "type": "mermaid",
                                        "code": "flowchart LR\n    dns[DNS query] -- Is HTTP request? --> proxy[HTTP proxy]\n    dns --> leak[Leak]\n    tcp[TCP connection] -- Is HTTP request? --> proxy\n    tcp -- Check and use HTTP CONNECT? --> proxy\n    tcp --> leak\n    udp[UDP packet] --> leak"
                                    }
                                },
                                {
                                    "name": "Firewall Redirection",
                                    "description": "This type of usage typically relies on the firewall or hook interface provided by the operating system, such as Windows’ WFP, Linux’s redirect, TProxy and eBPF, and macOS’s pf. Although it is intrusive and cumbersome to configure, it remains popular within the community of amateur proxy open source projects like V2Ray, due to the low technical requirements it imposes on the software."
                                },
                                {
                                    "name": "Virtual Interface",
                                    "description": "All L2/L3 proxies (seriously defined VPNs, such as OpenVPN, WireGuard) are based on virtual network interfaces, which is also the only way for all L4 proxies to work as VPNs on mobile platforms like Android, iOS.",
                                    "implementation": "The sing-box inherits and develops clash-premium’s TUN inbound (L3 to L4 conversion) as the most reasonable method for performing transparent proxying.",
                                    "diagram": {
                                        "type": "mermaid",
                                        "code": "flowchart TB\n    packet[IP Packet]\n    packet --> windows[Windows / macOS]\n    packet --> linux[Linux]\n    tun[TUN interface]\n    windows -. route .-> tun\n    linux -. iproute2 route/rule .-> tun\n    tun --> gvisor[gVisor TUN stack]\n    tun --> system[system TUN stack]\n    assemble([L3 to L4 assemble])\n    gvisor --> assemble\n    system --> assemble\n    assemble --> conn[TCP and UDP connections]\n    conn --> router[sing-box Router]\n    router --> direct[Direct outbound]\n    router --> proxy[Proxy outbounds]\n    router -- DNS hijack --> dns_out[DNS outbound]\n    dns_out --> dns_router[DNS router]\n    dns_router --> router\n    direct --> adi([auto detect interface])\n    proxy --> adi\n    adi --> default[Default network interface in the system]\n    default --> destination[Destination server]\n    default --> proxy_server[Proxy server]\n    proxy_server --> destination"
                                    }
                                }
                            ]
                        },
                        "examples": {
                            "title": ":material-cellphone-link: Examples",
                            "basic_tun_usage": {
                                "title": "Basic TUN usage for Chinese users",
                                "ipv4_only": {
                                    "title": ":material-numeric-4-box: IPv4 only",
                                    "configuration": {
                                        "dns": {
                                            "servers": [
                                                {
                                                    "tag": "google",
                                                    "address": "tls://8.8.8.8"
                                                },
                                                {
                                                    "tag": "local",
                                                    "address": "223.5.5.5",
                                                    "detour": "direct"
                                                }
                                            ],
                                            "rules": [
                                                {
                                                    "outbound": "any",
                                                    "server": "local"
                                                }
                                            ],
                                            "strategy": "ipv4_only"
                                        },
                                        "inbounds": [
                                            {
                                                "type": "tun",
                                                "inet4_address": "172.19.0.1/30",
                                                "auto_route": true,
                                                "strict_route": false
                                            }
                                        ],
                                        "outbounds": [
                                            {
                                                "type": "direct",
                                                "tag": "direct"
                                            },
                                            {
                                                "type": "dns",
                                                "tag": "dns-out"
                                            }
                                        ],
                                        "route": {
                                            "rules": [
                                                {
                                                    "protocol": "dns",
                                                    "outbound": "dns-out"
                                                },
                                                {
                                                    "geoip": [
                                                        "private"
                                                    ],
                                                    "outbound": "direct"
                                                }
                                            ],
                                            "auto_detect_interface": true
                                        }
                                    }
                                },
                                "ipv4_ipv6": {
                                    "title": ":material-numeric-6-box: IPv4 & IPv6",
                                    "configuration": {
                                        "dns": {
                                            "servers": [
                                                {
                                                    "tag": "google",
                                                    "address": "tls://8.8.8.8"
                                                },
                                                {
                                                    "tag": "local",
                                                    "address": "223.5.5.5",
                                                    "detour": "direct"
                                                }
                                            ],
                                            "rules": [
                                                {
                                                    "outbound": "any",
                                                    "server": "local"
                                                }
                                            ]
                                        },
                                        "inbounds": [
                                            {
                                                "type": "tun",
                                                "inet4_address": "172.19.0.1/30",
                                                "inet6_address": "fdfe:dcba:9876::1/126",
                                                "auto_route": true,
                                                "strict_route": false
                                            }
                                        ],
                                        "outbounds": [
                                            {
                                                "type": "direct",
                                                "tag": "direct"
                                            },
                                            {
                                                "type": "dns",
                                                "tag": "dns-out"
                                            }
                                        ],
                                        "route": {
                                            "rules": [
                                                {
                                                    "protocol": "dns",
                                                    "outbound": "dns-out"
                                                },
                                                {
                                                    "geoip": [
                                                        "private"
                                                    ],
                                                    "outbound": "direct"
                                                }
                                            ],
                                            "auto_detect_interface": true
                                        }
                                    }
                                },
                                "fakeip": {
                                    "title": ":material-domain-switch: FakeIP",
                                    "configuration": {
                                        "dns": {
                                            "servers": [
                                                {
                                                    "tag": "google",
                                                    "address": "tls://8.8.8.8"
                                                },
                                                {
                                                    "tag": "local",
                                                    "address": "223.5.5.5",
                                                    "detour": "direct"
                                                },
                                                {
                                                    "tag": "remote",
                                                    "address": "fakeip"
                                                }
                                            ],
                                            "rules": [
                                                {
                                                    "outbound": "any",
                                                    "server": "local"
                                                },
                                                {
                                                    "query_type": [
                                                        "A",
                                                        "AAAA"
                                                    ],
                                                    "server": "remote"
                                                }
                                            ],
                                            "fakeip": {
                                                "enabled": true,
                                                "inet4_range": "198.18.0.0/15",
                                                "inet6_range": "fc00::/18"
                                            },
                                            "independent_cache": true
                                        },
                                        "inbounds": [
                                            {
                                                "type": "tun",
                                                "inet4_address": "172.19.0.1/30",
                                                "inet6_address": "fdfe:dcba:9876::1/126",
                                                "auto_route": true,
                                                "strict_route": true
                                            }
                                        ],
                                        "outbounds": [
                                            {
                                                "type": "direct",
                                                "tag": "direct"
                                            },
                                            {
                                                "type": "dns",
                                                "tag": "dns-out"
                                            }
                                        ],
                                        "route": {
                                            "rules": [
                                                {
                                                    "protocol": "dns",
                                                    "outbound": "dns-out"
                                                },
                                                {
                                                    "geoip": [
                                                        "private"
                                                    ],
                                                    "outbound": "direct"
                                                }
                                            ],
                                            "auto_detect_interface": true
                                        }
                                    }
                                }
                            },
                            "traffic_bypass_usage": {
                                "title": "Traffic bypass usage for Chinese users",
                                "dns_rules": {
                                    "title": ":material-dns: DNS rules",
                                    "configuration": {
                                        "dns": {
                                            "servers": [
                                                {
                                                    "tag": "google",
                                                    "address": "tls://8.8.8.8"
                                                },
                                                {
                                                    "tag": "local",
                                                    "address": "223.5.5.5",
                                                    "detour": "direct"
                                                }
                                            ],
                                            "rules": [
                                                {
                                                    "outbound": "any",
                                                    "server": "local"
                                                },
                                                {
                                                    "clash_mode": "Direct",
                                                    "server": "local"
                                                },
                                                {
                                                    "clash_mode": "Global",
                                                    "server": "google"
                                                },
                                                {
                                                    "rule_set": "geosite-geolocation-cn",
                                                    "server": "local"
                                                }
                                            ]
                                        },
                                        "route": {
                                            "rule_set": [
                                                {
                                                    "type": "remote",
                                                    "tag": "geosite-geolocation-cn",
                                                    "format": "binary",
                                                    "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs"
                                                }
                                            ]
                                        }
                                    }
                                },
                                "dns_rules_enhanced": {
                                    "title": ":material-dns: DNS rules (Enhanced, but slower) (1.9.0+)",
                                    "with_dns_leaks": {
                                        "title": ":material-shield-off: With DNS leaks",
                                        "configuration": {
                                            "dns": {
                                                "servers": [
                                                    {
                                                        "tag": "google",
                                                        "address": "tls://8.8.8.8"
                                                    },
                                                    {
                                                        "tag": "local",
                                                        "address": "https://223.5.5.5/dns-query",
                                                        "detour": "direct"
                                                    }
                                                ],
                                                "rules": [
                                                    {
                                                        "outbound": "any",
                                                        "server": "local"
                                                    },
                                                    {
                                                        "clash_mode": "Direct",
                                                        "server": "local"
                                                    },
                                                    {
                                                        "clash_mode": "Global",
                                                        "server": "google"
                                                    },
                                                    {
                                                        "rule_set": "geosite-geolocation-cn",
                                                        "server": "local"
                                                    },
                                                    {
                                                        "clash_mode": "Default",
                                                        "server": "google"
                                                    },
                                                    {
                                                        "type": "logical",
                                                        "mode": "and",
                                                        "rules": [
                                                            {
                                                                "rule_set": "geosite-geolocation-!cn",
                                                                "invert": true
                                                            },
                                                            {
                                                                "rule_set": "geoip-cn"
                                                            }
                                                        ],
                                                        "server": "local"
                                                    }
                                                ]
                                            },
                                            "route": {
                                                "rule_set": [
                                                    {
                                                        "type": "remote",
                                                        "tag": "geosite-geolocation-cn",
                                                        "format": "binary",
                                                        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs"
                                                    },
                                                    {
                                                        "type": "remote",
                                                        "tag": "geosite-geolocation-!cn",
                                                        "format": "binary",
                                                        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs"
                                                    },
                                                    {
                                                        "type": "remote",
                                                        "tag": "geoip-cn",
                                                        "format": "binary",
                                                        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs"
                                                    }
                                                ]
                                            },
                                            "experimental": {
                                                "cache_file": {
                                                    "enabled": true,
                                                    "store_rdrc": true
                                                },
                                                "clash_api": {
                                                    "default_mode": "Enhanced"
                                                }
                                            }
                                        }
                                    },
                                    "without_dns_leaks": {
                                        "title": ":material-security: Without DNS leaks, but slower (1.9.0-alpha.2+)",
                                        "configuration": {
                                            "dns": {
                                                "servers": [
                                                    {
                                                        "tag": "google",
                                                        "address": "tls://8.8.8.8"
                                                    },
                                                    {
                                                        "tag": "local",
                                                        "address": "https://223.5.5.5/dns-query",
                                                        "detour": "direct"
                                                    }
                                                ],
                                                "rules": [
                                                    {
                                                        "outbound": "any",
                                                        "server": "local"
                                                    },
                                                    {
                                                        "clash_mode": "Direct",
                                                        "server": "local"
                                                    },
                                                    {
                                                        "clash_mode": "Global",
                                                        "server": "google"
                                                    },
                                                    {
                                                        "rule_set": "geosite-geolocation-cn",
                                                        "server": "local"
                                                    },
                                                    {
                                                        "type": "logical",
                                                        "mode": "and",
                                                        "rules": [
                                                            {
                                                                "rule_set": "geosite-geolocation-!cn",
                                                                "invert": true
                                                            },
                                                            {
                                                                "rule_set": "geoip-cn"
                                                            }
                                                        ],
                                                        "server": "google",
                                                        "client_subnet": "114.114.114.114/24"
                                                    }
                                                ]
                                            },
                                            "route": {
                                                "rule_set": [
                                                    {
                                                        "type": "remote",
                                                        "tag": "geosite-geolocation-cn",
                                                        "format": "binary",
                                                        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs"
                                                    },
                                                    {
                                                        "type": "remote",
                                                        "tag": "geosite-geolocation-!cn",
                                                        "format": "binary",
                                                        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs"
                                                    },
                                                    {
                                                        "type": "remote",
                                                        "tag": "geoip-cn",
                                                        "format": "binary",
                                                        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs"
                                                    }
                                                ]
                                            },
                                            "experimental": {
                                                "cache_file": {
                                                    "enabled": true,
                                                    "store_rdrc": true
                                                },
                                                "clash_api": {
                                                    "default_mode": "Enhanced"
                                                }
                                            }
                                        }
                                    }
                                },
                                "route_rules": {
                                    "title": ":material-router-network: Route rules",
                                    "configuration": {
                                        "outbounds": [
                                            {
                                                "type": "direct",
                                                "tag": "direct"
                                            },
                                            {
                                                "type": "block",
                                                "tag": "block"
                                            }
                                        ],
                                        "route": {
                                            "rules": [
                                                {
                                                    "type": "logical",
                                                    "mode": "or",
                                                    "rules": [
                                                        {
                                                            "protocol": "dns"
                                                        },
                                                        {
                                                            "port": 53
                                                        }
                                                    ],
                                                    "outbound": "dns"
                                                },
                                                {
                                                    "ip_is_private": true,
                                                    "outbound": "direct"
                                                },
                                                {
                                                    "clash_mode": "Direct",
                                                    "outbound": "direct"
                                                },
                                                {
                                                    "clash_mode": "Global",
                                                    "outbound": "default"
                                                },
                                                {
                                                    "type": "logical",
                                                    "mode": "or",
                                                    "rules": [
                                                        {
                                                            "port": 853
                                                        },
                                                        {
                                                            "network": "udp",
                                                            "port": 443
                                                        },
                                                        {
                                                            "protocol": "stun"
                                                        }
                                                    ],
                                                    "outbound": "block"
                                                },
                                                {
                                                    "rule_set": [
                                                        "geoip-cn",
                                                        "geosite-geolocation-cn"
                                                    ],
                                                    "outbound": "direct"
                                                }
                                            ],
                                            "rule_set": [
                                                {
                                                    "type": "remote",
                                                    "tag": "geoip-cn",
                                                    "format": "binary",
                                                    "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs"
                                                },
                                                {
                                                    "type": "remote",
                                                    "tag": "geosite-geolocation-cn",
                                                    "format": "binary",
                                                    "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs"
                                                }
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "proxy-protocol": {
                    "shadowsocks": {
                        "title": "Shadowsocks",
                        "description": "Shadowsocks is the most well-known Chinese-made proxy protocol. It exists in multiple versions, but only AEAD 2022 ciphers over TCP with multiplexing is recommended.",
                        "ciphers": {
                            "headers": [
                                "Ciphers",
                                "Specification",
                                "Cryptographically sound",
                                "Resists passive detection",
                                "Resists active probes"
                            ],
                            "rows": [
                                {
                                    "ciphers": "Stream Ciphers",
                                    "specification": "[shadowsocks.org](https://shadowsocks.org/doc/stream.html)",
                                    "cryptographically_sound": ":material-alert:",
                                    "resists_passive_detection": ":material-alert:",
                                    "resists_active_probes": ":material-alert:"
                                },
                                {
                                    "ciphers": "AEAD",
                                    "specification": "[shadowsocks.org](https://shadowsocks.org/doc/aead.html)",
                                    "cryptographically_sound": ":material-check:",
                                    "resists_passive_detection": ":material-alert:",
                                    "resists_active_probes": ":material-alert:"
                                },
                                {
                                    "ciphers": "AEAD 2022",
                                    "specification": "[shadowsocks.org](https://shadowsocks.org/doc/sip022.html)",
                                    "cryptographically_sound": ":material-check:",
                                    "resists_passive_detection": ":material-check:",
                                    "resists_active_probes": ":material-help:"
                                }
                            ],
                            "multiplexing_note": "(We strongly recommend using multiplexing to send UDP traffic over TCP, because doing otherwise is vulnerable to passive detection.)"
                        },
                        "password_generator": {
                            "title": ":material-text-box-check: Password Generator",
                            "cipher_password_table": {
                                "headers": [
                                    "For `2022-blake3-aes-128-gcm` cipher",
                                    "For other ciphers",
                                    "Action"
                                ],
                                "rows": [
                                    {
                                        "cipher": "<code id=\"password_16\"><code>",
                                        "other_cipher": "<code id=\"password_32\"><code>",
                                        "action": "<button class=\"md-button\" onclick=\"generate()\">Refresh</button>"
                                    }
                                ],
                                "script": "function generatePassword(element, length) {\n        const array = new Uint8Array(length);\n        window.crypto.getRandomValues(array);\n        document.getElementById(element).textContent = btoa(String.fromCharCode.apply(null, array));\n    }\n    function generate() {\n      generatePassword(\"password_16\", 16);\n      generatePassword(\"password_32\", 32);\n    }\n    generate();"
                            }
                        },
                        "server_example": {
                            "title": ":material-server: Server Example",
                            "single_user": {
                                "title": ":material-account: Single-user",
                                "configuration": {
                                    "inbounds": [
                                        {
                                            "type": "shadowsocks",
                                            "listen": "::",
                                            "listen_port": 8080,
                                            "network": "tcp",
                                            "method": "2022-blake3-aes-128-gcm",
                                            "password": "<password>",
                                            "multiplex": {
                                                "enabled": true
                                            }
                                        }
                                    ]
                                }
                            },
                            "multi_user": {
                                "title": ":material-account-multiple: Multi-user",
                                "configuration": {
                                    "inbounds": [
                                        {
                                            "type": "shadowsocks",
                                            "listen": "::",
                                            "listen_port": 8080,
                                            "network": "tcp",
                                            "method": "2022-blake3-aes-128-gcm",
                                            "password": "<server_password>",
                                            "users": [
                                                {
                                                    "name": "sekai",
                                                    "password": "<user_password>"
                                                }
                                            ],
                                            "multiplex": {
                                                "enabled": true
                                            }
                                        }
                                    ]
                                }
                            }
                        },
                        "client_example": {
                            "title": ":material-cellphone-link: Client Example",
                            "single_user": {
                                "title": ":material-account: Single-user",
                                "configuration": {
                                    "outbounds": [
                                        {
                                            "type": "shadowsocks",
                                            "server": "127.0.0.1",
                                            "server_port": 8080,
                                            "method": "2022-blake3-aes-128-gcm",
                                            "password": "<pasword>",
                                            "multiplex": {
                                                "enabled": true
                                            }
                                        }
                                    ]
                                }
                            },
                            "multi_user": {
                                "title": ":material-account-multiple: Multi-user",
                                "configuration": {
                                    "outbounds": [
                                        {
                                            "type": "shadowsocks",
                                            "server": "127.0.0.1",
                                            "server_port": 8080,
                                            "method": "2022-blake3-aes-128-gcm",
                                            "password": "<server_pasword>:<user_password>",
                                            "multiplex": {
                                                "enabled": true
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "trojan": {
                        "title": "Trojan",
                        "description": "Torjan is the most commonly used TLS proxy made in China. It can be used in various combinations, but only the combination of uTLS and multiplexing is recommended.",
                        "protocol_combinations": {
                            "headers": [
                                "Protocol and implementation combination",
                                "Specification",
                                "Resists passive detection",
                                "Resists active probes"
                            ],
                            "rows": [
                                {
                                    "combination": "Origin / trojan-gfw",
                                    "specification": "[trojan-gfw.github.io](https://trojan-gfw.github.io/trojan/protocol)",
                                    "resists_passive_detection": ":material-check:",
                                    "resists_active_probes": ":material-check:"
                                },
                                {
                                    "combination": "Basic Go implementation",
                                    "specification": "/",
                                    "resists_passive_detection": ":material-alert:",
                                    "resists_active_probes": ":material-check:"
                                },
                                {
                                    "combination": "with privates transport by V2Ray",
                                    "specification": "No formal definition",
                                    "resists_passive_detection": ":material-alert:",
                                    "resists_active_probes": ":material-alert:"
                                },
                                {
                                    "combination": "with uTLS enabled",
                                    "specification": "No formal definition",
                                    "resists_passive_detection": ":material-help:",
                                    "resists_active_probes": ":material-check:"
                                }
                            ]
                        },
                        "password_generator": {
                            "title": ":material-text-box-check: Password Generator",
