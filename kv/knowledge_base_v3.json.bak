                        },
                        "tailscale": {
                            "title": "Tailscale",
                            "description": "Configuration for a Tailscale DNS server.",
                            "since": "Since sing-box 1.12.0",
                            "structure": {
                                "title": "Structure",
                                "json": {
                                    "dns": {
                                        "servers": [
                                            {
                                                "type": "tailscale",
                                                "tag": "",
                                                "endpoint": "ts-ep",
                                                "accept_default_resolvers": false
                                            }
                                        ]
                                    }
                                }
                            },
                            "fields": {
                                "title": "Fields",
                                "endpoint": {
                                    "title": "endpoint",
                                    "description": "The tag of the Tailscale endpoint.",
                                    "required": true
                                },
                                "accept_default_resolvers": {
                                    "title": "accept_default_resolvers",
                                    "description": "Indicates whether default DNS resolvers should be accepted for fallback queries in addition to MagicDNS。\nif not enabled, NXDOMAIN will be returned for non-Tailscale domain queries."
                                }
                            },
                            "examples": {
                                "magicdns_only": {
                                    "title": "MagicDNS only",
                                    "configuration": {
                                        "json": {
                                            "dns": {
                                                "servers": [
                                                    {
                                                        "type": "local",
                                                        "tag": "local"
                                                    },
                                                    {
                                                        "type": "tailscale",
                                                        "tag": "ts",
                                                        "endpoint": "ts-ep"
                                                    }
                                                ],
                                                "rules": [
                                                    {
                                                        "ip_accept_any": true,
                                                        "server": "ts"
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                },
                                "use_as_global_dns": {
                                    "title": "Use as global DNS",
                                    "configuration": {
                                        "json": {
                                            "dns": {
                                                "servers": [
                                                    {
                                                        "type": "tailscale",
                                                        "endpoint": "ts-ep",
                                                        "accept_default_resolvers": true
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "rule": {
                        "title": "DNS Rule",
                        "description": "Defines rules for DNS resolution.",
                        "changes": {
                            "sing_box_1.12.0": {
                                "title": "Changes in sing-box 1.12.0",
                                "features": [
                                    "[ip_accept_any](#ip_accept_any)",
                                    "[outbound](#outbound) (Deprecated)"
