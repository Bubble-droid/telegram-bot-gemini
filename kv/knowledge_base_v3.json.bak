                                "title": "rules",
                                "description": "==Required== Included rules."
                            }
                        }
                    },
                    "rule_action": {
                        "title": "DNS Rule Actions",
                        "description": "Defines actions to be taken for DNS rules.",
                        "changes": {
                            "sing_box_1.12.0": {
                                "title": "Changes in sing-box 1.12.0",
                                "features": [
                                    "[strategy](#strategy)",
                                    "[predefined](#predefined)"
                                ]
                            }
                        },
                        "since_sing_box_1.11.0": {
                            "title": "Since sing-box 1.11.0"
                        },
                        "route": {
                            "title": "route",
                            "description": "`route` inherits the classic rule behavior of routing DNS requests to the specified server.",
                            "json": {
                                "action": "route",
                                "server": "",
                                "strategy": "",
                                "disable_cache": false,
                                "rewrite_ttl": null,
                                "client_subnet": null
                            },
                            "fields": {
                                "server": {
                                    "title": "server",
                                    "description": "Tag of target server.",
                                    "required": true
                                },
                                "strategy": {
                                    "title": "strategy",
                                    "description": "Set domain strategy for this query. One of `prefer_ipv4` `prefer_ipv6` `ipv4_only` `ipv6_only`.",
                                    "since": "Since sing-box 1.12.0"
                                },
                                "disable_cache": {
                                    "title": "disable_cache",
                                    "description": "Disable cache and save cache in this query."
                                },
                                "rewrite_ttl": {
                                    "title": "rewrite_ttl",
                                    "description": "Rewrite TTL in DNS responses."
                                },
                                "client_subnet": {
                                    "title": "client_subnet",
                                    "description": "Append a `edns0-subnet` OPT extra record with the specified IP prefix to every query by default. If value is an IP address instead of prefix, `/32` or `/128` will be appended automatically. Will overrides `dns.client_subnet`."
                                }
                            }
                        },
                        "route_options": {
                            "title": "route-options",
                            "description": "`route-options` set options for routing.",
                            "json": {
                                "action": "route-options",
                                "disable_cache": false,
                                "rewrite_ttl": null,
                                "client_subnet": null
                            }
                        },
                        "reject": {
                            "title": "reject",
                            "description": "`reject` reject DNS requests.",
                            "json": {
                                "action": "reject",
                                "method": "",
                                "no_drop": false
                            },
                            "fields": {
                                "method": {
                                    "title": "method",
                                    "description": " - `default`: Reply with NXDOMAIN. - `drop`: Drop the request.  `default` will be used by default."
                                },
                                "no_drop": {
                                    "title": "no_drop",
                                    "description": "If not enabled, `method` will be temporarily overwritten to `drop` after 50 triggers in 30s. Not available when `method` is set to drop."
                                }
                            }
                        },
                        "predefined": {
                            "title": "predefined",
                            "description": "`predefined` responds with predefined DNS records.",
                            "since": "Since sing-box 1.12.0",
                            "json": {
                                "action": "predefined",
                                "rcode": "",
                                "answer": [],
                                "ns": [],
                                "extra": []
                            },
                            "fields": {
                                "rcode": {
                                    "title": "rcode",
                                    "description": "The response code.",
                                    "table": {
                                        "headers": [
                                            "Value",
                                            "Value in the legacy rcode server",
                                            "Description"
                                        ],
                                        "rows": [
                                            {
                                                "value": "`NOERROR`",
                                                "legacy_value": "`success`",
                                                "description": "Ok"
                                            },
                                            {
                                                "value": "`FORMERR`",
                                                "legacy_value": "`format_error`",
                                                "description": "Bad request"
                                            },
                                            {
                                                "value": "`SERVFAIL`",
                                                "legacy_value": "`server_failure`",
                                                "description": "Server failure"
                                            },
                                            {
                                                "value": "`NXDOMAIN`",
                                                "legacy_value": "`name_error`",
                                                "description": "Not found"
                                            },
                                            {
                                                "value": "`NOTIMP`",
                                                "legacy_value": "`not_implemented`",
                                                "description": "Not implemented"
                                            },
                                            {
                                                "value": "`REFUSED`",
                                                "legacy_value": "`refused`",
                                                "description": "Refused"
                                            }
                                        ]
                                    },
                                    "default": "`NOERROR` will be used by default."
                                },
                                "answer": {
                                    "title": "answer",
                                    "description": "List of text DNS record to respond as answers.",
                                    "examples": {
                                        "table": {
                                            "headers": [
                                                "Record Type",
                                                "Example"
                                            ],
                                            "rows": [
                                                {
                                                    "record_type": "`A`",
                                                    "example": "`localhost. IN A 127.0.0.1`"
                                                },
                                                {
                                                    "record_type": "`AAAA`",
                                                    "example": "`localhost. IN AAAA ::1`"
                                                },
                                                {
                                                    "record_type": "`TXT`",
                                                    "example": "`localhost. IN TXT \"Hello\"`"
                                                }
                                            ]
                                        }
                                    }
                                },
                                "ns": {
                                    "title": "ns",
                                    "description": "List of text DNS record to respond as name servers."
                                },
                                "extra": {
                                    "title": "extra",
                                    "description": "List of text DNS record to respond as extra records."
                                }
                            }
                        }
                    }
                },
                "ntp": {
                    "title": "NTP",
                    "description": "Built-in NTP client service. If enabled, it will provide time for protocols like TLS/Shadowsocks/VMess, which is useful for environments where time synchronization is not possible.",
                    "structure": {
                        "title": "Structure",
                        "json": {
                            "ntp": {
                                "enabled": false,
                                "server": "time.apple.com",
                                "server_port": 123,
                                "interval": "30m",
                                "dial_fields": "... // Dial Fields"
                            }
                        }
                    },
                    "fields": {
                        "title": "Fields",
                        "enabled": {
                            "title": "enabled",
                            "description": "Enable NTP service."
                        },
                        "server": {
                            "title": "server",
                            "description": "NTP server address.",
                            "required": true
                        },
                        "server_port": {
                            "title": "server_port",
                            "description": "NTP server port. 123 is used by default."
                        },
                        "interval": {
                            "title": "interval",
                            "description": "Time synchronization interval. 30 minutes is used by default."
                        }
                    },
                    "dial_fields": {
                        "title": "Dial Fields",
                        "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                    }
                },
                "certificate": {
                    "title": "Certificate",
                    "description": "Defines settings for trusted X509 CA certificates.",
                    "since": "Since sing-box 1.12.0",
                    "structure": {
                        "title": "Structure",
                        "json": {
                            "store": "",
                            "certificate": [],
                            "certificate_path": [],
                            "certificate_directory_path": []
                        },
                        "note": "You can ignore the JSON Array [] tag when the content is only one item"
                    },
                    "fields": {
                        "title": "Fields",
                        "store": {
                            "title": "store",
                            "description": "The default X509 trusted CA certificate list.",
                            "table": {
                                "headers": [
                                    "Type",
                                    "Description"
                                ],
                                "rows": [
                                    {
                                        "type": "`system` (default)",
                                        "description": "System trusted CA certificates"
                                    },
                                    {
                                        "type": "`mozilla`",
                                        "description": "[Mozilla Included List](https://wiki.mozilla.org/CA/Included_Certificates) with China CA certificates removed"
                                    },
                                    {
                                        "type": "`none`",
                                        "description": "Empty list"
                                    }
                                ]
                            }
                        },
                        "certificate": {
                            "title": "certificate",
                            "description": "The certificate line array to trust, in PEM format."
                        },
                        "certificate_path": {
                            "title": "certificate_path",
                            "description": "The paths to certificates to trust, in PEM format.",
                            "note": "Will be automatically reloaded if file modified."
                        },
                        "certificate_directory_path": {
                            "title": "certificate_directory_path",
                            "description": "The directory path to search for certificates to trust,in PEM format.",
                            "note": "Will be automatically reloaded if file modified."
                        }
                    }
                },
                "route": {
