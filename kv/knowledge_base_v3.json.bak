                    "tuic": {
                        "title": "TUIC",
                        "description": "Configuration for a TUIC server.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "tuic",
                                "tag": "tuic-in",
                                "listen_fields": "... // Listen Fields",
                                "users": [
                                    {
                                        "name": "sekai",
                                        "uuid": "059032A9-7D40-4A96-9BB1-36823D848068",
                                        "password": "hello"
                                    }
                                ],
                                "congestion_control": "cubic",
                                "auth_timeout": "3s",
                                "zero_rtt_handshake": false,
                                "heartbeat": "10s",
                                "tls": {}
                            }
                        },
                        "listen_fields": {
                            "title": "Listen Fields",
                            "description": "See [Listen Fields](/configuration/shared/listen/) for details."
                        },
                        "fields": {
                            "title": "Fields",
                            "users": {
                                "title": "users",
                                "description": "TUIC users",
                                "user_fields": {
                                    "uuid": {
                                        "title": "users.uuid",
                                        "description": "==Required== TUIC user uuid"
                                    },
                                    "password": {
                                        "title": "users.password",
                                        "description": "TUIC user password"
                                    }
                                }
                            },
                            "congestion_control": {
                                "title": "congestion_control",
                                "description": "QUIC congestion control algorithm. One of: `cubic`, `new_reno`, `bbr` `cubic` is used by default."
                            },
                            "auth_timeout": {
                                "title": "auth_timeout",
                                "description": "How long the server should wait for the client to send the authentication command. `3s` is used by default."
                            },
                            "zero_rtt_handshake": {
                                "title": "zero_rtt_handshake",
                                "description": "Enable 0-RTT QUIC connection handshake on the client side. This is not impacting much on the performance, as the protocol is fully multiplexed.",
                                "warning": "Disabling this is highly recommended, as it is vulnerable to replay attacks. See [Attack of the clones](https://blog.cloudflare.com/even-faster-connection-establishment-with-quic-0-rtt-resumption/#attack-of-the-clones)"
                            },
                            "heartbeat": {
                                "title": "heartbeat",
                                "description": "Interval for sending heartbeat packets for keeping the connection alive. `10s` is used by default."
                            },
                            "tls": {
                                "title": "tls",
                                "description": "==Required== TLS configuration, see [TLS](/configuration/shared/tls/#inbound)."
                            }
                        }
                    },
                    "hysteria2": {
                        "title": "Hysteria2",
                        "description": "Configuration for a Hysteria2 server.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "hysteria2",
                                "tag": "hy2-in",
                                "listen_fields": "... // Listen Fields",
                                "up_mbps": 100,
                                "down_mbps": 100,
                                "obfs": {
                                    "type": "salamander",
                                    "password": "cry_me_a_r1ver"
                                },
                                "users": [
                                    {
                                        "name": "tobyxdd",
                                        "password": "goofy_ahh_password"
                                    }
                                ],
                                "ignore_client_bandwidth": false,
                                "tls": {},
                                "masquerade": "",
                                "brutal_debug": false
                            }
                        },
                        "warning": {
                            "title": "Difference from official Hysteria2",
                            "description": "The official program supports an authentication method called **userpass**, which essentially uses a combination of `<username>:<password>` as the actual password, while sing-box does not provide this alias. To use sing-box with the official program, you need to fill in that combination as the actual password."
                        },
                        "listen_fields": {
                            "title": "Listen Fields",
                            "description": "See [Listen Fields](/configuration/shared/listen/) for details."
                        },
                        "fields": {
                            "title": "Fields",
                            "up_mbps_down_mbps": {
                                "title": "up_mbps, down_mbps",
                                "description": "Max bandwidth, in Mbps. Not limited if empty. Conflict with `ignore_client_bandwidth`."
                            },
                            "obfs": {
                                "title": "obfs.type",
                                "description": "QUIC traffic obfuscator type, only available with `salamander`. Disabled if empty.",
                                "obfs_fields": {
                                    "password": {
                                        "title": "obfs.password",
                                        "description": "QUIC traffic obfuscator password."
                                    }
                                }
                            },
                            "users": {
                                "title": "users",
                                "description": "Hysteria2 users",
                                "user_fields": {
                                    "password": {
                                        "title": "users.password",
                                        "description": "Authentication password"
                                    }
                                }
                            },
                            "ignore_client_bandwidth": {
                                "title": "ignore_client_bandwidth",
                                "description": "*When `up_mbps` and `down_mbps` are not set*: Commands clients to use the BBR CC instead of Hysteria CC. *When `up_mbps` and `down_mbps` are set*: Deny clients to use the BBR CC."
                            },
                            "tls": {
                                "title": "tls",
                                "description": "==Required== TLS configuration, see [TLS](/configuration/shared/tls/#inbound)."
                            },
                            "masquerade": {
                                "title": "masquerade",
                                "description": "HTTP3 server behavior (URL string configuration) when authentication fails. A 404 page will be returned if masquerade is not configured. Conflict with `masquerade.type`.",
                                "table": {
                                    "headers": [
                                        "Scheme",
                                        "Example",
                                        "Description"
                                    ],
                                    "rows": [
                                        {
                                            "scheme": "`file`",
                                            "example": "`file:///var/www`",
                                            "description": "As a file server"
                                        },
                                        {
                                            "scheme": "`http/https`",
                                            "example": "`http://127.0.0.1:8080`",
                                            "description": "As a reverse proxy"
                                        }
                                    ]
                                }
                            },
                            "masquerade_type": {
                                "title": "masquerade.type",
                                "description": "HTTP3 server behavior (Object configuration) when authentication fails. A 404 page will be returned if masquerade is not configured. Conflict with `masquerade`.",
                                "table": {
                                    "headers": [
                                        "Type",
                                        "Description",
                                        "Fields"
                                    ],
                                    "rows": [
                                        {
                                            "type": "`file`",
                                            "description": "As a file server",
                                            "fields": "`directory`"
                                        },
                                        {
                                            "type": "`proxy`",
                                            "description": "As a reverse proxy",
                                            "fields": "`url`, `rewrite_host`"
                                        },
                                        {
                                            "type": "`string`",
                                            "description": "Reply with a fixed response",
                                            "fields": "`status_code`, `headers`, `content`"
                                        }
                                    ]
                                }
                            },
                            "masquerade_directory": {
                                "title": "masquerade.directory",
                                "description": "File server root directory."
                            },
                            "masquerade_url": {
                                "title": "masquerade.url",
                                "description": "Reverse proxy target URL."
                            },
                            "masquerade_rewrite_host": {
                                "title": "masquerade.rewrite_host",
                                "description": "Rewrite the `Host` header to the target URL."
                            },
                            "masquerade_status_code": {
                                "title": "masquerade.status_code",
                                "description": "Fixed response status code."
                            },
                            "masquerade_headers": {
                                "title": "masquerade.headers",
                                "description": "Fixed response headers."
                            },
                            "masquerade_content": {
                                "title": "masquerade.content",
                                "description": "Fixed response content."
                            },
                            "brutal_debug": {
                                "title": "brutal_debug",
                                "description": "Enable debug information logging for Hysteria Brutal CC."
                            }
                        }
                    },
