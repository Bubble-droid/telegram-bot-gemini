                            {
                                "type": "vless",
                                "tag": "Proxy1",
                                "server": "xxx.xxx.xxx.xxx",
                                "server_port": 443,
                                "uuid": "..."
                            },
                            {
                                "type": "shadowsocks",
                                "tag": "Proxy2"
                            }
                        ]
                    },
