                            },
                            {
                                "option": "禁用日志",
                                "description": "对应 Sing-Box 的 `log.disabled` 字段，启用后将不输出日志。"
                            },
                            {
                                "option": "日志级别",
                                "description": "对应 Sing-Box 的 `log.level` 字段，设置日志输出级别，等级由低到高：",
                                "log_levels": [
                                    {
                                        "level": "跟踪 (trace)",
                                        "description": "详细的调试信息，通常用于开发。"
