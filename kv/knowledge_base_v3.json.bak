                                "title": "users",
                                "description": "Hysteria users",
                                "user_fields": {
                                    "auth": {
                                        "title": "users.auth",
                                        "description": "Authentication password, in base64."
                                    },
                                    "auth_str": {
                                        "title": "users.auth_str",
                                        "description": "Authentication password."
                                    }
                                }
                            },
                            "recv_window_conn": {
                                "title": "recv_window_conn",
                                "description": "The QUIC stream-level flow control window for receiving data. `15728640 (15 MB/s)` will be used if empty."
                            },
                            "recv_window_client": {
                                "title": "recv_window_client",
                                "description": "The QUIC connection-level flow control window for receiving data. `67108864 (64 MB/s)` will be used if empty."
                            },
                            "max_conn_client": {
                                "title": "max_conn_client",
                                "description": "The maximum number of QUIC concurrent bidirectional streams that a peer is allowed to open. `1024` will be used if empty."
                            },
                            "disable_mtu_discovery": {
                                "title": "disable_mtu_discovery",
                                "description": "Disables Path MTU Discovery (RFC 8899). Packets will then be at most 1252 (IPv4) / 1232 (IPv6) bytes in size. Force enabled on for systems other than Linux and Windows (according to upstream)."
                            },
                            "tls": {
                                "title": "tls",
                                "description": "==Required== TLS configuration, see [TLS](/configuration/shared/tls/#inbound)."
                            }
                        }
                    },
