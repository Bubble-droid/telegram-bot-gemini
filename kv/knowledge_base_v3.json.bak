                "misc": {
                    "tunnelvision": {
                        "title": "TunnelVision",
                        "description": "TunnelVision is an attack that uses DHCP option 121 to set higher priority routes so that traffic does not go through the VPN.",
                        "reference": "https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-2024-3661",
                        "status": {
                            "title": "Status",
                            "android": {
                                "description": "Android does not handle DHCP option 121 and is not affected."
                            },
                            "apple_platforms": {
                                "description": "Update [sing-box graphical client](/clients/apple/#download) to `1.9.0-rc.16` or newer, then enable `includeAllNetworks` in `Settings` — `Packet Tunnel` and you will be unaffected.",
                                "note": "Note: when `includeAllNetworks` is enabled, the default TUN stack is changed to `gvisor`, and the `system` and `mixed` stacks are not available."
                            },
                            "linux": {
                                "description": "Update sing-box to `1.9.0-rc.16` or newer, rules generated by `auto-route` are unaffected."
                            },
                            "windows": {
                                "description": "No solution yet."
                            }
                        },
                        "workarounds": {
                            "title": "Workarounds",
                            "solutions": [
                                "Don't connect to untrusted networks",
                                "Relay untrusted network through another device",
                                "Just ignore it"
                            ]
                        }
                    }
                }
            },
            "configuration": {
                "main": {
                    "title": "Introduction",
                    "description": "sing-box uses JSON for configuration files.",
                    "structure": {
                        "title": "Structure",
                        "json": {
                            "log": {},
                            "dns": {},
                            "ntp": {},
                            "certificate": {},
                            "endpoints": [],
                            "inbounds": [],
                            "outbounds": [],
                            "route": {},
                            "experimental": {}
                        }
                    },
                    "fields": {
                        "title": "Fields",
                        "table": {
                            "headers": [
                                "Key",
                                "Format"
                            ],
                            "rows": [
                                {
                                    "key": "`log`",
                                    "format": "[Log](./log/)"
                                },
                                {
                                    "key": "`dns`",
                                    "format": "[DNS](./dns/)"
                                },
                                {
                                    "key": "`ntp`",
                                    "format": "[NTP](./ntp/)"
                                },
                                {
                                    "key": "`certificate`",
                                    "format": "[Certificate](./certificate/)"
                                },
                                {
                                    "key": "`endpoints`",
                                    "format": "[Endpoint](./endpoint/)"
                                },
                                {
                                    "key": "`inbounds`",
                                    "format": "[Inbound](./inbound/)"
                                },
                                {
                                    "key": "`outbounds`",
                                    "format": "[Outbound](./outbound/)"
                                },
                                {
                                    "key": "`route`",
                                    "format": "[Route](./route/)"
                                },
                                {
                                    "key": "`experimental`",
                                    "format": "[Experimental](./experimental/)"
                                }
                            ]
                        }
                    },
                    "check": {
                        "title": "Check",
                        "command": "sing-box check"
                    },
                    "format": {
                        "title": "Format",
                        "command": "sing-box format -w -c config.json -D config_directory"
                    },
                    "merge": {
                        "title": "Merge",
                        "command": "sing-box merge output.json -c config.json -D config_directory"
                    }
                },
                "log": {
                    "title": "Log",
                    "structure": {
                        "title": "Structure",
                        "json": {
                            "log": {
                                "disabled": false,
                                "level": "info",
                                "output": "box.log",
                                "timestamp": true
                            }
                        }
                    },
                    "fields": {
                        "title": "Fields",
                        "disabled": {
                            "title": "disabled",
                            "description": "Disable logging, no output after start."
                        },
                        "level": {
                            "title": "level",
                            "description": "Log level. One of: `trace` `debug` `info` `warn` `error` `fatal` `panic`."
                        },
                        "output": {
                            "title": "output",
                            "description": "Output file path. Will not write log to console after enable."
                        },
                        "timestamp": {
                            "title": "timestamp",
                            "description": "Add time to each line."
                        }
                    }
                },
                "dns": {
                    "main": {
                        "title": "DNS",
                        "description": "Defines DNS settings for sing-box.",
                        "changes": {
                            "sing_box_1.11.0": {
                                "title": "Changes in sing-box 1.11.0",
                                "features": [
                                    "[cache_capacity](#cache_capacity)"
                                ]
                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "dns": {
                                    "servers": [],
                                    "rules": [],
                                    "final": "",
                                    "strategy": "",
                                    "disable_cache": false,
                                    "disable_expire": false,
                                    "independent_cache": false,
                                    "cache_capacity": 0,
                                    "reverse_mapping": false,
                                    "client_subnet": "",
                                    "fakeip": {}
                                }
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "server": {
                                "title": "`server`",
                                "format": "List of [DNS Server](./server/)"
                            },
                            "rules": {
                                "title": "`rules`",
                                "format": "List of [DNS Rule](./rule/)"
                            },
                            "fakeip": {
                                "title": "`fakeip`",
                                "format": "[FakeIP](./fakeip/)"
                            },
                            "final": {
                                "title": "final",
                                "description": "Default dns server tag. The first server will be used if empty."
                            },
                            "strategy": {
                                "title": "strategy",
                                "description": "Default domain strategy for resolving the domain names. One of `prefer_ipv4` `prefer_ipv6` `ipv4_only` `ipv6_only`."
                            },
                            "disable_cache": {
                                "title": "disable_cache",
                                "description": "Disable dns cache."
                            },
                            "disable_expire": {
                                "title": "disable_expire",
                                "description": "Disable dns cache expire."
                            },
                            "independent_cache": {
                                "title": "independent_cache",
                                "description": "Make each DNS server's cache independent for special purposes. If enabled, will slightly degrade performance."
                            },
                            "cache_capacity": {
                                "title": "cache_capacity",
                                "description": "LRU cache capacity.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Value less than 1024 will be ignored."
                            },
                            "reverse_mapping": {
                                "title": "reverse_mapping",
                                "description": "Stores a reverse mapping of IP addresses after responding to a DNS query in order to provide domain names when routing. Since this process relies on the act of resolving domain names by an application before making a request, it can be problematic in environments such as macOS, where DNS is proxied and cached by the system."
                            },
                            "client_subnet": {
                                "title": "client_subnet",
                                "description": "Append a `edns0-subnet` OPT extra record with the specified IP prefix to every query by default. If value is an IP address instead of prefix, `/32` or `/128` will be appended automatically.",
                                "since": "Since sing-box 1.9.0",
                                "note": "Can be overrides by `servers.[].client_subnet` or `rules.[].client_subnet`."
                            }
                        }
                    },
                    "server": {
                        "main": {
                            "title": "DNS Server",
                            "description": "Defines the configuration for DNS servers.",
                            "changes": {
                                "sing_box_1.12.0": {
                                    "title": "Changes in sing-box 1.12.0",
                                    "features": [
                                        "[type](#type)"
                                    ]
                                }
                            },
                            "structure": {
                                "title": "Structure",
                                "json": {
                                    "dns": {
                                        "servers": [
                                            {
                                                "type": "",
                                                "tag": ""
                                            }
                                        ]
                                    }
                                }
                            },
                            "fields": {
                                "title": "Fields",
                                "type": {
                                    "title": "type",
                                    "description": "The type of the DNS server.",
                                    "table": {
                                        "headers": [
                                            "Type",
                                            "Format"
                                        ],
                                        "rows": [
                                            {
                                                "type": "empty (default)",
                                                "format": "[Legacy](./legacy/)"
                                            },
                                            {
                                                "type": "`tcp`",
                                                "format": "[TCP](./tcp/)"
                                            },
                                            {
                                                "type": "`udp`",
                                                "format": "[UDP](./udp/)"
                                            },
                                            {
                                                "type": "`tls`",
                                                "format": "[TLS](./tls/)"
                                            },
                                            {
                                                "type": "`https`",
                                                "format": "[HTTPS](./https/)"
                                            },
                                            {
                                                "type": "`quic`",
                                                "format": "[QUIC](./quic/)"
                                            },
                                            {
                                                "type": "`h3`",
                                                "format": "[HTTP/3](./http3/)"
                                            },
                                            {
                                                "type": "`predefined`",
                                                "format": "[Predefined](./predefined/)"
                                            },
                                            {
                                                "type": "`dhcp`",
                                                "format": "[DHCP](./dhcp/)"
                                            },
                                            {
                                                "type": "`fakeip`",
                                                "format": "[Fake IP](./fakeip/)"
                                            },
                                            {
                                                "type": "`tailscale`",
                                                "format": "[Tailscale](./tailscale/)"
                                            }
                                        ]
                                    }
                                },
                                "tag": {
                                    "title": "tag",
                                    "description": "The tag of the DNS server."
                                }
                            }
                        },
                        "local": {
                            "title": "Local",
                            "description": "Configuration for a local DNS server.",
                            "since": "Since sing-box 1.12.0",
                            "structure": {
                                "title": "Structure",
                                "json": {
                                    "dns": {
                                        "servers": [
                                            {
                                                "type": "local",
                                                "tag": "",
                                                "dial_fields": "// Dial Fields"
                                            }
                                        ]
                                    }
                                }
                            },
                            "info": {
                                "title": "Difference from legacy local server",
                                "points": [
                                    "The old legacy local server only handles IP requests; the new one handles all types of requests and supports concurrent for IP requests.",
                                    "The old local server uses default outbound by default unless detour is specified; the new one uses dialer just like outbound, which is equivalent to using an empty direct outbound by default."
                                ]
                            },
                            "dial_fields": {
                                "title": "Dial Fields",
                                "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                            }
                        },
                        "hosts": {
                            "title": "Hosts",
                            "description": "Configuration for a hosts file DNS server.",
                            "since": "Since sing-box 1.12.0",
                            "structure": {
                                "title": "Structure",
                                "json": {
                                    "dns": {
                                        "servers": [
                                            {
                                                "type": "hosts",
                                                "tag": "",
                                                "path": [],
                                                "predefined": {}
                                            }
                                        ]
                                    }
                                },
                                "note": "You can ignore the JSON Array [] tag when the content is only one item"
                            },
                            "fields": {
                                "title": "Fields",
                                "path": {
                                    "title": "path",
                                    "description": "List of paths to hosts files.",
                                    "default": "/etc/hosts is used by default. C:\\Windows\\System32\\Drivers\\etc\\hosts is used by default on Windows.",
                                    "example": {
                                        "json": {
                                            "path": [
                                                "/etc/hosts",
                                                "$HOME/.hosts"
                                            ]
                                        }
                                    }
                                },
                                "predefined": {
                                    "title": "predefined",
                                    "description": "Predefined hosts.",
                                    "example": {
                                        "json": {
                                            "predefined": {
                                                "www.google.com": "127.0.0.1",
                                                "localhost": [
                                                    "127.0.0.1",
                                                    "::1"
                                                ]
                                            }
                                        }
                                    }
                                }
                            },
                            "examples": {
                                "use_hosts_if_available": {
                                    "title": "Use hosts if available",
                                    "configuration": {
                                        "json": {
                                            "dns": {
                                                "servers": [
                                                    {
                                                        "...": "..."
                                                    },
                                                    {
                                                        "type": "hosts",
                                                        "tag": "hosts"
                                                    }
                                                ],
                                                "rules": [
                                                    {
                                                        "ip_accept_any": true,
                                                        "server": "hosts"
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        },
                        "tcp": {
                            "title": "TCP",
                            "description": "Configuration for a TCP DNS server.",
                            "since": "Since sing-box 1.12.0",
                            "structure": {
                                "title": "Structure",
                                "json": {
                                    "dns": {
                                        "servers": [
                                            {
                                                "type": "tcp",
                                                "tag": "",
                                                "server": "",
                                                "server_port": 53,
                                                "dial_fields": "// Dial Fields"
                                            }
                                        ]
                                    }
                                }
                            },
                            "info": {
                                "title": "Difference from legacy TCP server",
                                "points": [
                                    "The old server uses default outbound by default unless detour is specified; the new one uses dialer just like outbound, which is equivalent to using an empty direct outbound by default.",
                                    "The old server uses `address_resolver` and `address_strategy` to resolve the domain name in the server; the new one uses `domain_resolver` and `domain_strategy` in [Dial Fields](/configuration/shared/dial/) instead."
                                ]
                            },
                            "fields": {
                                "title": "Fields",
                                "server": {
                                    "title": "server",
                                    "description": "The address of the DNS server.",
                                    "required": true,
                                    "note": "If domain name is used, `domain_resolver` must also be set to resolve IP address."
                                },
                                "server_port": {
                                    "title": "server_port",
                                    "description": "The port of the DNS server.",
                                    "default": "53"
                                }
                            },
                            "dial_fields": {
                                "title": "Dial Fields",
                                "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                            }
                        },
                        "udp": {
                            "title": "UDP",
                            "description": "Configuration for a UDP DNS server.",
