                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "quic://1.1.1.1"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "quic",
                                                                "server": "1.1.1.1"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "http3": {
                                            "deprecated": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "h3://1.1.1.1/dns-query"
                                                            }
                                                        ]
                                                    }
                                                }
                                            },
                                            "new": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "type": "h3",
                                                                "server": "1.1.1.1"
                                                            }
                                                        ]
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    {
                                        "dhcp": {
                                            "deprecated": {
                                                "configuration": {
                                                    "dns": {
                                                        "servers": [
                                                            {
                                                                "address": "dhcp://auto"
                                                            },
                                                            {
                                                                "address": "dhcp://en0"
                                                            }
                                                        ]
                                                    }
