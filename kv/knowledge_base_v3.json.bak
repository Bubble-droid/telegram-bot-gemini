                            "udp_relay_mode": {
                                "title": "udp_relay_mode",
                                "description": "UDP packet relay mode",
                                "table": {
                                    "headers": [
                                        "Mode",
                                        "Description"
                                    ],
                                    "rows": [
                                        {
                                            "mode": "native",
                                            "description": "native UDP characteristics"
                                        },
                                        {
                                            "mode": "quic",
                                            "description": "lossless UDP relay using QUIC streams, additional overhead is introduced"
                                        }
                                    ]
                                },
                                "default": "`native` is used by default.",
                                "conflict_with": "`udp_over_stream`"
                            },
                            "udp_over_stream": {
                                "title": "udp_over_stream",
                                "description": "This is the TUIC port of the [UDP over TCP protocol](/configuration/shared/udp-over-tcp/), designed to provide a QUIC stream based UDP relay mode that TUIC does not provide. Since it is an add-on protocol, you will need to use sing-box or another program compatible with the protocol as a server. This mode has no positive effect in a proper UDP proxy scenario and should only be applied to relay streaming UDP traffic (basically QUIC streams).",
                                "conflict_with": "`udp_relay_mode`"
                            },
                            "zero_rtt_handshake": {
                                "title": "zero_rtt_handshake",
                                "description": "Enable 0-RTT QUIC connection handshake on the client side This is not impacting much on the performance, as the protocol is fully multiplexed",
                                "warning": "Disabling this is highly recommended, as it is vulnerable to replay attacks. See [Attack of the clones](https://blog.cloudflare.com/even-faster-connection-establishment-with-quic-0-rtt-resumption/#attack-of-the-clones)"
                            },
                            "heartbeat": {
                                "title": "heartbeat",
                                "description": "Interval for sending heartbeat packets for keeping the connection alive. `10s` is used by default."
                            },
                            "network": {
                                "title": "network",
                                "description": "Enabled network. One of `tcp` `udp`. Both is enabled by default."
                            },
                            "tls": {
                                "title": "tls",
                                "description": "==Required== TLS configuration, see [TLS](/configuration/shared/tls/#outbound)."
                            }
                        },
                        "dial_fields": {
                            "title": "Dial Fields",
                            "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                        }
                    },
                    "hysteria2": {
                        "title": "Hysteria2",
                        "description": "Configuration for a Hysteria2 client.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "hysteria2",
                                "tag": "hy2-out",
                                "server": "127.0.0.1",
                                "server_port": 1080,
                                "server_ports": [
                                    "2080:3000"
                                ],
                                "hop_interval": "",
                                "up_mbps": 100,
                                "down_mbps": 100,
                                "obfs": {
                                    "type": "salamander",
                                    "password": "cry_me_a_r1ver"
                                },
                                "password": "goofy_ahh_password",
                                "network": "tcp",
                                "tls": {},
                                "brutal_debug": false,
                                "dial_fields": "... // Dial Fields"
                            },
                            "note": "You can ignore the JSON Array [] tag when the content is only one item"
                        },
                        "warning": {
                            "title": "Difference from official Hysteria2",
                            "description": "The official Hysteria2 supports an authentication method called **userpass**, which essentially uses a combination of `<username>:<password>` as the actual password, while sing-box does not provide this alias. If you are planning to use sing-box with the official program, please note that you will need to fill the combination as the password."
                        },
                        "fields": {
                            "title": "Fields",
                            "server": {
                                "title": "server",
                                "description": "==Required== The server address."
                            },
                            "server_port": {
                                "title": "server_port",
                                "description": "==Required== The server port. Ignored if `server_ports` is set."
                            },
                            "server_ports": {
                                "title": "server_ports",
                                "description": "Server port range list.",
                                "since": "Since sing-box 1.11.0",
                                "conflicts_with": "`server_port`"
                            },
                            "hop_interval": {
                                "title": "hop_interval",
                                "description": "Port hopping interval. `30s` is used by default.",
                                "since": "Since sing-box 1.11.0"
                            },
                            "up_mbps_down_mbps": {
                                "title": "up_mbps, down_mbps",
                                "description": "Max bandwidth, in Mbps. If empty, the BBR congestion control algorithm will be used instead of Hysteria CC."
                            },
                            "obfs": {
                                "title": "obfs.type",
                                "description": "QUIC traffic obfuscator type, only available with `salamander`. Disabled if empty.",
                                "obfs_fields": {
                                    "password": {
                                        "title": "obfs.password",
                                        "description": "QUIC traffic obfuscator password."
                                    }
                                }
                            },
                            "password": {
                                "title": "password",
                                "description": "Authentication password."
                            },
                            "network": {
                                "title": "network",
                                "description": "Enabled network One of `tcp` `udp`. Both is enabled by default."
                            },
                            "tls": {
                                "title": "tls",
                                "description": "==Required== TLS configuration, see [TLS](/configuration/shared/tls/#outbound)."
                            },
                            "brutal_debug": {
                                "title": "brutal_debug",
                                "description": "Enable debug information logging for Hysteria Brutal CC."
                            }
                        },
                        "dial_fields": {
                            "title": "Dial Fields",
                            "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                        }
                    },
                    "anytls": {
                        "title": "AnyTLS",
                        "description": "Configuration for an AnyTLS client.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "anytls",
                                "tag": "anytls-out",
                                "server": "127.0.0.1",
                                "server_port": 1080,
                                "password": "8JCsPssfgS8tiRwiMlhARg==",
                                "idle_session_check_interval": "30s",
                                "idle_session_timeout": "30s",
                                "min_idle_session": 5,
                                "tls": {},
                                "dial_fields": "... // Dial Fields"
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "server": {
                                "title": "server",
                                "description": "==Required== The server address."
                            },
                            "server_port": {
                                "title": "server_port",
                                "description": "==Required== The server port."
                            },
                            "password": {
                                "title": "password",
                                "description": "==Required== The AnyTLS password."
                            },
                            "idle_session_check_interval": {
                                "title": "idle_session_check_interval",
                                "description": "Interval checking for idle sessions. Default: 30s."
                            },
                            "idle_session_timeout": {
                                "title": "idle_session_timeout",
                                "description": "In the check, close sessions that have been idle for longer than this. Default: 30s."
                            },
                            "min_idle_session": {
                                "title": "min_idle_session",
                                "description": "In the check, at least the first `n` idle sessions are kept open. Default value: `n`=0"
                            },
                            "tls": {
                                "title": "tls",
                                "description": "==Required== TLS configuration, see [TLS](/configuration/shared/tls/#outbound)."
                            }
                        },
                        "dial_fields": {
                            "title": "Dial Fields",
                            "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                        }
                    },
                    "tor": {
                        "title": "Tor",
                        "description": "Configuration for a Tor client.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "tor",
                                "tag": "tor-out",
                                "executable_path": "/usr/bin/tor",
                                "extra_args": [],
                                "data_directory": "$HOME/.cache/tor",
                                "torrc": {
                                    "ClientOnly": 1
                                },
                                "dial_fields": "... // Dial Fields"
                            },
                            "info": "Embedded Tor is not included by default, see [Installation](/installation/build-from-source/#build-tags)."
                        },
                        "fields": {
                            "title": "Fields",
                            "executable_path": {
                                "title": "executable_path",
                                "description": "The path to the Tor executable. Embedded Tor will be ignored if set."
                            },
                            "extra_args": {
                                "title": "extra_args",
                                "description": "List of extra arguments passed to the Tor instance when started."
                            },
                            "data_directory": {
                                "title": "data_directory",
                                "description": "==Recommended== The data directory of Tor. Each start will be very slow if not specified."
                            },
                            "torrc": {
                                "title": "torrc",
                                "description": "Map of torrc options. See [tor(1)](https://linux.die.net/man/1/tor) for details."
                            }
                        },
                        "dial_fields": {
                            "title": "Dial Fields",
                            "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                        }
                    },
                    "ssh": {
                        "title": "SSH",
                        "description": "Configuration for an SSH client.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "ssh",
                                "tag": "ssh-out",
                                "server": "127.0.0.1",
                                "server_port": 22,
                                "user": "root",
                                "password": "admin",
                                "private_key": "",
                                "private_key_path": "$HOME/.ssh/id_rsa",
                                "private_key_passphrase": "",
                                "host_key": [
                                    "ecdsa-sha2-nistp256 AAAAE2VjZHNhLXNoYTItbmlzdH..."
                                ],
                                "host_key_algorithms": [],
                                "client_version": "SSH-2.0-OpenSSH_7.4p1",
                                "dial_fields": "... // Dial Fields"
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "server": {
                                "title": "server",
                                "description": "==Required== Server address."
                            },
                            "server_port": {
                                "title": "server_port",
                                "description": "Server port. 22 will be used if empty."
                            },
                            "user": {
                                "title": "user",
                                "description": "SSH user, root will be used if empty."
                            },
                            "password": {
                                "title": "password",
                                "description": "Password."
                            },
                            "private_key": {
                                "title": "private_key",
                                "description": "Private key."
                            },
                            "private_key_path": {
                                "title": "private_key_path",
                                "description": "Private key path."
                            },
                            "private_key_passphrase": {
                                "title": "private_key_passphrase",
                                "description": "Private key passphrase."
                            },
                            "host_key": {
                                "title": "host_key",
                                "description": "Host key. Accept any if empty."
                            },
                            "host_key_algorithms": {
                                "title": "host_key_algorithms",
                                "description": "Host key algorithms."
                            },
                            "client_version": {
                                "title": "client_version",
                                "description": "Client version. Random version will be used if empty."
                            }
                        },
                        "dial_fields": {
                            "title": "Dial Fields",
                            "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                        }
                    },
                    "selector": {
                        "title": "Selector",
                        "description": "Allows selecting between multiple outbounds.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "selector",
                                "tag": "select",
                                "outbounds": [
                                    "proxy-a",
                                    "proxy-b",
                                    "proxy-c"
                                ],
                                "default": "proxy-c",
                                "interrupt_exist_connections": false
                            },
                            "note": "The selector can only be controlled through the [Clash API](/configuration/experimental#clash-api-fields) currently."
                        },
                        "fields": {
                            "title": "Fields",
                            "outbounds": {
                                "title": "outbounds",
                                "description": "==Required== List of outbound tags to select."
                            },
                            "default": {
                                "title": "default",
                                "description": "The default outbound tag. The first outbound will be used if empty."
                            },
                            "interrupt_exist_connections": {
                                "title": "interrupt_exist_connections",
                                "description": "Interrupt existing connections when the selected outbound has changed. Only inbound connections are affected by this setting, internal connections will always be interrupted."
                            }
                        }
                    },
                    "urltest": {
                        "title": "URLTest",
                        "description": "Tests the availability of outbounds by accessing a URL.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "urltest",
                                "tag": "auto",
                                "outbounds": [
                                    "proxy-a",
                                    "proxy-b",
                                    "proxy-c"
                                ],
                                "url": "",
                                "interval": "",
                                "tolerance": 50,
                                "idle_timeout": "",
                                "interrupt_exist_connections": false
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "outbounds": {
                                "title": "outbounds",
                                "description": "==Required== List of outbound tags to test."
                            },
                            "url": {
                                "title": "url",
                                "description": "The URL to test. `https://www.gstatic.com/generate_204` will be used if empty."
                            },
                            "interval": {
                                "title": "interval",
                                "description": "The test interval. `3m` will be used if empty."
                            },
                            "tolerance": {
                                "title": "tolerance",
                                "description": "The test tolerance in milliseconds. `50` will be used if empty."
                            },
                            "idle_timeout": {
                                "title": "idle_timeout",
                                "description": "The idle timeout. `30m` will be used if empty."
                            },
                            "interrupt_exist_connections": {
                                "title": "interrupt_exist_connections",
                                "description": "Interrupt existing connections when the selected outbound has changed. Only inbound connections are affected by this setting, internal connections will always be interrupted."
                            }
                        }
                    }
                }
            }
        },
        "sing_box_examples": {
            "hysteria": {
                "config_client": {
                    "title": "Hysteria Client Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "mixed",
                                    "listen": "::",
                                    "listen_port": 10000
                                }
                            ],
                            "outbounds": [
                                {
                                    "type": "hysteria",
                                    "server": "",
                                    "server_port": 443,
                                    "up_mbps": 20,
                                    "down_mbps": 100,
                                    "auth_str": "",
                                    "tls": {
                                        "enabled": true,
                                        "server_name": "",
                                        "alpn": [
                                            "h3"
                                        ]
                                    }
                                }
                            ]
                        }
                    }
                },
                "config_server": {
                    "title": "Hysteria Server Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "hysteria",
                                    "listen": "::",
                                    "listen_port": 443,
                                    "up_mbps": 100,
                                    "down_mbps": 20,
                                    "users": [
                                        {
                                            "auth_str": ""
                                        }
                                    ],
                                    "tls": {
                                        "enabled": true,
                                        "alpn": [
                                            "h3"
                                        ],
                                        "certificate_path": "/root/fullchain.cer",
                                        "key_path": "/root/private.key"
                                    }
                                }
                            ],
                            "outbounds": [
                                {
                                    "type": "direct"
                                }
                            ]
                        }
                    }
                }
            },
            "hysteria2": {
                "config_client": {
                    "title": "Hysteria2 Client Example",
