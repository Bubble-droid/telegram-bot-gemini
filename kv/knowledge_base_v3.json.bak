            "shadowsocks": {
                "config_client": {
                    "title": "Shadowsocks Client Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "mixed",
                                    "listen": "::",
                                    "listen_port": 10000
                                }
                            ],
                            "outbounds": [
                                {
                                    "type": "shadowsocks",
                                    "server": "",
                                    "server_port": 80,
                                    "method": "2022-blake3-aes-128-gcm",
                                    "password": "",
