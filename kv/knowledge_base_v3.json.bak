                                    "[rule_set_ip_cidr_accept_empty](#rule_set_ip_cidr_accept_empty)",
                                    "[process_path_regex](#process_path_regex)"
                                ]
                            },
                            "sing_box_1.9.0": {
                                "title": "Changes in sing-box 1.9.0",
