                                    "provider": "cloudflare",
                                    "api_token": ""
                                }
                            }
                        }
                    },
                    "multiplex": {
                        "title": "Multiplex",
                        "inbound": {
                            "title": "Inbound",
                            "structure": {
                                "json": {
                                    "enabled": true,
                                    "padding": false,
                                    "brutal": {}
                                }
                            },
                            "fields": {
                                "enabled": {
                                    "title": "enabled",
                                    "description": "Enable multiplex support."
                                },
                                "padding": {
                                    "title": "padding",
                                    "description": "If enabled, non-padded connections will be rejected."
                                },
                                "brutal": {
                                    "title": "brutal",
                                    "description": "See [TCP Brutal](/configuration/shared/tcp-brutal/) for details."
                                }
                            }
                        },
                        "outbound": {
                            "title": "Outbound",
                            "structure": {
                                "json": {
                                    "enabled": true,
                                    "protocol": "smux",
                                    "max_connections": 4,
                                    "min_streams": 4,
                                    "max_streams": 0,
                                    "padding": false,
                                    "brutal": {}
                                }
                            },
                            "fields": {
                                "enabled": {
                                    "title": "enabled",
                                    "description": "Enable multiplex."
                                },
                                "protocol": {
                                    "title": "protocol",
                                    "description": "Multiplex protocol",
                                    "table": {
                                        "headers": [
                                            "Protocol",
                                            "Description"
                                        ],
                                        "rows": [
                                            {
                                                "protocol": "smux",
                                                "description": "https://github.com/xtaci/smux"
                                            },
                                            {
                                                "protocol": "yamux",
                                                "description": "https://github.com/hashicorp/yamux"
                                            },
                                            {
                                                "protocol": "h2mux",
                                                "description": "https://golang.org/x/net/http2"
                                            }
                                        ],
                                        "default": "h2mux is used by default."
                                    }
                                },
                                "max_connections": {
                                    "title": "max_connections",
                                    "description": "Maximum connections. Conflict with `max_streams`."
                                },
                                "min_streams": {
                                    "title": "min_streams",
                                    "description": "Minimum multiplexed streams in a connection before opening a new connection. Conflict with `max_streams`.",
                                    "conflict_with": "`max_streams`"
                                },
                                "max_streams": {
                                    "title": "max_streams",
                                    "description": "Maximum multiplexed streams in a connection before opening a new connection. Conflict with `max_connections` and `min_streams`."
                                },
                                "padding": {
                                    "title": "padding",
                                    "description": "Enable padding.",
                                    "info": "Requires sing-box server version 1.3-beta9 or later."
                                },
                                "brutal": {
                                    "title": "brutal",
                                    "description": "See [TCP Brutal](/configuration/shared/tcp-brutal/) for details."
                                }
                            }
                        }
                    },
                    "udp-over-tcp": {
                        "title": "UDP over TCP",
                        "description": "The UDP over TCP protocol is used to transmit UDP packets in TCP.",
                        "warning": "It's a proprietary protocol created by SagerNet, not part of shadowsocks.",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "enabled": true,
                                "version": 2
                            },
                            "note": "The structure can be replaced with a boolean value when the version is not specified."
                        },
                        "fields": {
                            "title": "Fields",
                            "enabled": {
                                "title": "enabled",
                                "description": "Enable the UDP over TCP protocol."
                            },
                            "version": {
                                "title": "version",
                                "description": "The protocol version, `1` or `2`. 2 is used by default."
                            }
                        },
                        "application_support": {
                            "title": "Application support",
                            "table": {
                                "headers": [
                                    "Project",
                                    "UoT v1",
                                    "UoT v2"
                                ],
                                "rows": [
                                    {
                                        "project": "sing-box",
                                        "uot_v1": "v0 (2022/08/11)",
                                        "uot_v2": "v1.2-beta9"
                                    },
                                    {
                                        "project": "Clash.Meta",
                                        "uot_v1": "v1.12.0 (2022/07/02)",
                                        "uot_v2": "v1.14.3 (2023/03/31)"
                                    },
                                    {
                                        "project": "Shadowrocket",
                                        "uot_v1": "v2.2.12 (2022/08/13)",
                                        "uot_v2": "/"
                                    }
                                ]
                            }
                        },
                        "protocol_details": {
                            "title": "Protocol details",
                            "protocol_version_1": {
                                "title": "Protocol version 1",
                                "description": "The client requests the magic address to the upper layer proxy protocol to indicate the request: `sp.udp-over-tcp.arpa`"
                            },
                            "stream_format": {
                                "title": "Stream format",
                                "table": {
                                    "headers": [
                                        "ATYP",
                                        "address",
                                        "port",
                                        "length",
                                        "data"
                                    ],
                                    "rows": [
                                        {
                                            "atyp": "u8",
                                            "address": "variable",
                                            "port": "u16be",
                                            "length": "u16be",
                                            "data": "variable"
                                        }
                                    ],
                                    "address_format_note": "**ATYP / address / port**: Uses the SOCKS address format, but with different address types:",
                                    "address_type_table": {
                                        "headers": [
                                            "ATYP",
                                            "Address type"
                                        ],
                                        "rows": [
                                            {
                                                "atyp": "`0x00`",
                                                "address_type": "IPv4 Address"
                                            },
                                            {
                                                "atyp": "`0x01`",
                                                "address_type": "IPv6 Address"
                                            },
                                            {
                                                "atyp": "`0x02`",
                                                "address_type": "Domain Name"
                                            }
                                        ]
                                    }
                                }
                            },
                            "protocol_version_2": {
                                "title": "Protocol version 2",
                                "description": "Protocol version 2 uses a new magic address: `sp.v2.udp-over-tcp.arpa`",
                                "request_format": {
                                    "title": "Request format",
                                    "table": {
                                        "headers": [
                                            "isConnect",
                                            "ATYP",
                                            "address",
                                            "port"
                                        ],
                                        "rows": [
                                            {
                                                "isConnect": "u8",
                                                "atyp": "u8",
                                                "address": "variable",
                                                "port": "u16be"
                                            }
                                        ],
                                        "isconnect_note": "**isConnect**: Set to 1 to indicates that the stream uses the connect format, 0 to disable. **ATYP / address / port**: Request destination, uses the SOCKS address format."
                                    }
                                },
                                "connect_stream_format": {
                                    "title": "Connect stream format",
                                    "table": {
                                        "headers": [
                                            "length",
                                            "data"
                                        ],
                                        "rows": [
                                            {
                                                "length": "u16be",
                                                "data": "variable"
                                            }
                                        ]
                                    }
                                },
                                "non_connect_stream_format": {
                                    "title": "Non-connect stream format",
                                    "description": "As the same as the stream format in protocol version 1."
                                }
                            }
                        }
                    },
                    "tcp-brutal": {
                        "title": "TCP Brutal",
                        "description": "Configuration for the TCP Brutal congestion control algorithm.",
                        "server_requirements": {
                            "title": "Server Requirements",
                            "requirements": [
                                "Linux",
                                "`brutal` congestion control algorithm kernel module installed"
                            ],
                            "reference": "See [tcp-brutal](https://github.com/apernet/tcp-brutal) for details."
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "enabled": true,
                                "up_mbps": 100,
                                "down_mbps": 100
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "enabled": {
                                "title": "enabled",
                                "description": "Enable TCP Brutal congestion control algorithm。"
                            },
                            "up_mbps_down_mbps": {
                                "title": "up_mbps, down_mbps",
                                "description": "Upload and download bandwidth, in Mbps.",
                                "required": true
                            }
                        }
                    }
                },
                "endpoint": {
                    "main": {
                        "title": "Endpoint",
                        "description": "Endpoint is protocols that has both inbound and outbound behavior.",
                        "since": "Since sing-box 1.11.0",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "endpoints": [
                                    {
                                        "type": "",
                                        "tag": ""
                                    }
                                ]
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "type": {
                                "title": "type",
                                "description": "Type of endpoint."
                            },
                            "tag": {
                                "title": "tag",
                                "description": "The tag of the endpoint."
                            },
                            "table": {
                                "headers": [
                                    "Type",
                                    "Format"
                                ],
                                "rows": [
                                    {
                                        "type": "`wireguard`",
                                        "format": "[WireGuard](./wireguard/)"
                                    },
                                    {
                                        "type": "`tailscale`",
                                        "format": "[Tailscale](./tailscale/)"
                                    }
                                ]
                            }
                        }
                    },
                    "wireguard": {
                        "title": "WireGuard",
                        "description": "Configuration for a WireGuard endpoint.",
                        "since": "Since sing-box 1.11.0",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "wireguard",
                                "tag": "wg-ep",
                                "system": false,
                                "name": "",
                                "mtu": 1408,
                                "address": [],
                                "private_key": "",
                                "listen_port": 10000,
                                "peers": [
                                    {
                                        "address": "127.0.0.1",
                                        "port": 10001,
                                        "public_key": "",
                                        "pre_shared_key": "",
                                        "allowed_ips": [],
                                        "persistent_keepalive_interval": 0,
                                        "reserved": [
                                            0,
                                            0,
                                            0
                                        ]
                                    }
                                ],
                                "udp_timeout": "",
                                "workers": 0,
                                "dial_fields": "... // Dial Fields"
                            },
                            "note": "You can ignore the JSON Array [] tag when the content is only one item"
                        },
                        "fields": {
                            "title": "Fields",
                            "system": {
                                "title": "system",
                                "description": "Use system interface. Requires privilege and cannot conflict with exists system interfaces."
                            },
                            "name": {
                                "title": "name",
                                "description": "Custom interface name for system interface."
                            },
                            "mtu": {
                                "title": "mtu",
                                "description": "WireGuard MTU. `1408` will be used by default."
                            },
                            "address": {
                                "title": "address",
                                "description": "==Required== List of IP (v4 or v6) address prefixes to be assigned to the interface."
                            },
                            "private_key": {
                                "title": "private_key",
                                "description": "==Required== WireGuard requires base64-encoded public and private keys. These can be generated using the wg(8) utility: `wg genkey` `echo \"private key\" || wg pubkey` or `sing-box generate wg-keypair`."
                            },
                            "peers": {
                                "title": "peers",
                                "description": "==Required== List of WireGuard peers."
                            },
                            "peers_address": {
                                "title": "peers.address",
                                "description": "WireGuard peer address."
                            },
                            "peers_port": {
                                "title": "peers.port",
                                "description": "WireGuard peer port."
                            },
                            "peers_public_key": {
                                "title": "peers.public_key",
                                "description": "==Required== WireGuard peer public key."
                            },
                            "peers_pre_shared_key": {
                                "title": "peers.pre_shared_key",
                                "description": "WireGuard peer pre-shared key."
                            },
                            "peers_allowed_ips": {
                                "title": "peers.allowed_ips",
                                "description": "==Required== WireGuard allowed IPs."
                            },
                            "peers_persistent_keepalive_interval": {
                                "title": "peers.persistent_keepalive_interval",
                                "description": "WireGuard persistent keepalive interval, in seconds. Disabled by default."
                            },
                            "peers_reserved": {
                                "title": "peers.reserved",
                                "description": "WireGuard reserved field bytes."
                            },
                            "udp_timeout": {
                                "title": "udp_timeout",
                                "description": "UDP NAT expiration time. `5m` will be used by default."
                            },
                            "workers": {
                                "title": "workers",
                                "description": "WireGuard worker count. CPU count is used by default."
                            }
                        },
                        "dial_fields": {
                            "title": "Dial Fields",
                            "description": "See [Dial Fields](/configuration/shared/dial/) for details."
                        }
                    },
                    "tailscale": {
                        "title": "Tailscale",
                        "description": "Configuration for a Tailscale endpoint.",
                        "since": "Since sing-box 1.12.0",
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "type": "tailscale",
                                "tag": "ts-ep",
                                "state_directory": "",
                                "auth_key": "",
                                "control_url": "",
                                "ephemeral": false,
                                "hostname": "",
                                "exit_node": "",
                                "exit_node_allow_lan_access": false,
                                "advertise_routes": [],
                                "advertise_exit_node": false,
                                "udp_timeout": "5m",
                                "dial_fields": "... // Dial Fields"
                            }
                        },
                        "fields": {
                            "title": "Fields",
                            "state_directory": {
                                "title": "state_directory",
                                "description": "The directory where the Tailscale state is stored. `tailscale` is used by default. Example: `$HOME/.tailscale`"
                            },
                            "auth_key": {
                                "title": "auth_key",
                                "description": "The auth key to create the node. If the node is already created (from state previously stored), then this field is not used.",
                                "note": "Auth key is not required. By default, sing-box will log the login URL (or popup a notification on graphical clients)."
                            },
                            "control_url": {
                                "title": "control_url",
                                "description": "The coordination server URL. `https://controlplane.tailscale.com` is used by default."
                            },
                            "ephemeral": {
                                "title": "ephemeral",
                                "description": "Indicates whether the instance should register as an Ephemeral node (https://tailscale.com/s/ephemeral-nodes)."
                            },
                            "hostname": {
                                "title": "hostname",
                                "description": "The hostname of the node. System hostname is used by default. Example: `localhost`"
                            },
                            "exit_node": {
                                "title": "exit_node",
                                "description": "The exit node name or IP address to use."
                            },
                            "exit_node_allow_lan_access": {
                                "title": "exit_node_allow_lan_access",
                                "description": "Indicates whether locally accessible subnets should be routed directly or via the exit node.",
                                "note": "When the exit node does not have a corresponding advertised route, private traffics cannot be routed to the exit node even if `exit_node_allow_lan_access is` set."
                            },
                            "advertise_routes": {
                                "title": "advertise_routes",
                                "description": "CIDR prefixes to advertise into the Tailscale network as reachable through the current node. Example: `[\"192.168.1.1/24\"]`"
                            },
                            "advertise_exit_node": {
                                "title": "advertise_exit_node",
                                "description": "Indicates whether the node should advertise itself as an exit node."
                            },
                            "udp_timeout": {
                                "title": "udp_timeout",
                                "description": "UDP NAT expiration time. `5m` will be used by default."
                            }
                        },
                        "dial_fields": {
                            "title": "Dial Fields",
                            "description": "See [Dial Fields](/configuration/shared/dial/) for details.",
