            "shadowtls": {
                "config_client": {
                    "title": "ShadowTLS Client Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "mixed",
                                    "listen": "::",
                                    "listen_port": 10000
                                }
                            ],
                            "outbounds": [
                                {
                                    "type": "shadowsocks",
                                    "detour": "shadowtls-out",
                                    "method": "2022-blake3-aes-128-gcm",
                                    "password": "",
                                    "multiplex": {
                                        "enabled": true
                                    }
                                },
                                {
                                    "type": "shadowtls",
                                    "tag": "shadowtls-out",
                                    "server": "",
                                    "server_port": 443,
                                    "version": 3,
                                    "password": "",
                                    "tls": {
                                        "enabled": true,
                                        "server_name": "",
                                        "utls": {
                                            "enabled": true,
                                            "fingerprint": "chrome"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                },
                "config_server": {
                    "title": "ShadowTLS Server Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "shadowtls",
                                    "listen": "::",
                                    "listen_port": 443,
                                    "detour": "shadowsocks-in",
                                    "version": 3,
                                    "users": [
                                        {
                                            "password": ""
                                        }
                                    ],
                                    "handshake": {
                                        "server": "",
                                        "server_port": 443
                                    },
                                    "strict_mode": true
                                },
                                {
                                    "type": "shadowsocks",
                                    "tag": "shadowsocks-in",
                                    "listen": "127.0.0.1",
                                    "method": "2022-blake3-aes-128-gcm",
                                    "password": "",
                                    "multiplex": {
                                        "enabled": true
                                    }
                                }
                            ],
                            "outbounds": [
                                {
                                    "type": "direct"
                                }
                            ]
                        }
                    }
                }
            },
            "tcp_brutal": {
                "guide": {
                    "title": "TCP Brutal 使用指南",
                    "description": "TCP Brutal 使用指南",
                    "brutal_description": "[Brutal](https://hysteria.network/zh/docs/advanced/Full-Server-Config/#_6)：这是 [Hysteria](https://github.com/apernet/hysteria) 自有的拥塞控制算法。与 BBR 不同，Brutal 采用固定速率模型，丢包或 RTT 变化不会降低速度。相反，如果无法达到预定的目标速率，反而会根据计算的丢包率提高发送速率来进行补偿。Brutal 只在你知道（并正确设置了）当前网络的最大速度时才能正常运行。其擅长在拥塞的网络中抢占带宽，因此得名。",
                    "hysteria_is_multipacket": "[Hysteria 是多倍发包吗？](https://hysteria.network/zh/docs/misc/Hysteria-Brutal/)",
                    "my_response_to_the_recent_controversy": "[My response to the recent controversy about TCP Brutal](https://gist.github.com/tobyxdd/0993ac063b2eee94f7d36ddd786f52ce)",
                    "server_installation": {
                        "title": "服务端安装 [TCP Brutal](https://github.com/apernet/tcp-brutal/blob/master/README.zh.md#%E7%94%A8%E6%88%B7%E6%8C%87%E5%8D%97)",
                        "installation_script": "bash <(curl -fsSL https://tcp.hy2.sh/)",
                        "note": "需要内核版本 4.9 或以上，推荐使用 5.8 以上的内核。对于小于 5.8 的内核, 只支持 IPv4。"
                    },
                    "server_configuration": {
                        "title": "服务端配置",
                        "jsonc": {
                            "multiplex": {
                                "enabled": true,
                                "padding": false,
                                "brutal": {
                                    "enabled": true,
                                    "up_mbps": 100,
                                    "down_mbps": 20
                                }
                            }
                        },
                        "note": "需要 sing-box 版本 1.7.0 或更高。",
                        "vless_vision_realirty_note": "1.  **VLESS-Vision-REALITY / VLESS-Vision-TLS** 中 `\"flow\": \"\"` 必须留空，或不写 `\"flow\": \"\"`",
                        "padding_note": "2.  两端 **\"padding\"** 必须一致",
                        "up_mbps_note": "3.  服务端 **\"up_mbps\"** 小于 客户端 **\"down_mbps\"** 时，以服务端为准"
                    },
                    "client_configuration": {
                        "title": "客户端配置",
                        "jsonc": {
                            "multiplex": {
                                "enabled": true,
                                "protocol": "h2mux",
                                "max_connections": 1,
                                "min_streams": 4,
                                "padding": false,
                                "brutal": {
                                    "enabled": true,
                                    "up_mbps": 20,
                                    "down_mbps": 100
                                }
                            }
                        },
                        "note": "需要 sing-box 版本 1.7.0 或更高。",
                        "vless_vision_realirty_note": "1.  **VLESS-Vision-REALITY / VLESS-Vision-TLS** 中 `\"flow\": \"\"` 必须留空，或不写 `\"flow\": \"\"`",
                        "padding_note": "2.  两端 **\"padding\"** 必须一致",
                        "down_mbps_note": "3.  客户端 **\"down_mbps\"** 小于 服务端 **\"up_mbps\"** 时，以客户端为准"
                    }
                },
                "config_client": {
                    "title": "TCP Brutal Client Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "mixed",
                                    "listen": "::",
                                    "listen_port": 10000
                                }
                            ],
                            "outbounds": [
                                {
                                    "type": "vless",
                                    "server": "",
                                    "server_port": 443,
                                    "uuid": "",
                                    "tls": {
                                        "enabled": true,
                                        "server_name": "",
                                        "utls": {
                                            "enabled": true,
                                            "fingerprint": "chrome"
                                        }
                                    },
                                    "packet_encoding": "xudp",
                                    "multiplex": {
                                        "enabled": true,
                                        "protocol": "h2mux",
                                        "max_connections": 1,
                                        "min_streams": 4,
                                        "padding": false,
                                        "brutal": {
                                            "enabled": true,
                                            "up_mbps": 20,
                                            "down_mbps": 100
                                        }
                                    }
                                }
                            ]
                        }
                    }
                },
                "config_server": {
                    "title": "TCP Brutal Server Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "vless",
                                    "listen": "::",
                                    "listen_port": 443,
                                    "users": [
                                        {
                                            "uuid": ""
                                        }
                                    ],
                                    "tls": {
                                        "enabled": true,
                                        "certificate_path": "/root/fullchain.cer",
                                        "key_path": "/root/private.key"
                                    },
                                    "multiplex": {
                                        "enabled": true,
                                        "padding": false,
                                        "brutal": {
                                            "enabled": true,
                                            "up_mbps": 100,
                                            "down_mbps": 20
                                        }
                                    }
                                }
                            ],
                            "outbounds": [
                                {
                                    "type": "direct"
                                }
                            ]
                        }
                    }
                }
            },
