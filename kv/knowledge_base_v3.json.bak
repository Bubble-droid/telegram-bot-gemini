                    "service_management": {
                        "title": "Service Management",
                        "description": "For Linux systems with [systemd][systemd], usually the installation already includes a sing-box service, you can manage the service using the following command:",
                        "table": {
                            "headers": [
                                "Operation",
                                "Command"
                            ],
                            "rows": [
                                {
                                    "operation": "Enable",
                                    "command": "`sudo systemctl enable sing-box`"
                                },
                                {
                                    "operation": "Disable",
                                    "command": "`sudo systemctl disable sing-box`"
                                },
                                {
                                    "operation": "Start",
                                    "command": "`sudo systemctl start sing-box`"
                                },
                                {
                                    "operation": "Stop",
                                    "command": "`sudo systemctl stop sing-box`"
                                },
                                {
                                    "operation": "Kill",
                                    "command": "`sudo systemctl kill sing-box`"
                                },
                                {
                                    "operation": "Restart",
                                    "command": "`sudo systemctl restart sing-box`"
                                },
                                {
                                    "operation": "Logs",
                                    "command": "`sudo journalctl -u sing-box --output cat -e`"
                                },
                                {
                                    "operation": "New Logs",
                                    "command": "`sudo journalctl -u sing-box --output cat -f`"
                                }
                            ]
                        }
                    },
