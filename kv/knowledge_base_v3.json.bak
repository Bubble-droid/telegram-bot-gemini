                                    "type": "hysteria2",
                                    "server": "",
                                    "server_port": 443,
                                    "up_mbps": 20,
                                    "down_mbps": 100,
                                    "password": "",
                                    "tls": {
                                        "enabled": true,
                                        "server_name": "",
                                        "alpn": [
                                            "h3"
                                        ]
                                    }
                                }
                            ]
                        }
                    }
                },
                "config_server": {
                    "title": "Hysteria2 Server Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "hysteria2",
                                    "listen": "::",
                                    "listen_port": 443,
                                    "up_mbps": 100,
                                    "down_mbps": 20,
                                    "users": [
                                        {
                                            "password": ""
                                        }
                                    ],
                                    "tls": {
                                        "enabled": true,
