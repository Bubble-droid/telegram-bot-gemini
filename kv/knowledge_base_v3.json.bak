                "config_server": {
                    "title": "Shadowsocks Server Example",
                    "configuration": {
                        "json": {
                            "inbounds": [
                                {
                                    "type": "shadowsocks",
                                    "listen": "::",
                                    "listen_port": 80,
                                    "method": "2022-blake3-aes-128-gcm",
                                    "password": "",
