                                "script": "function generate() {\n        const array = new Uint8Array(16);\n        window.crypto.getRandomValues(array);\n        document.getElementById(\"password\").textContent = btoa(String.fromCharCode.apply(null, array));\n    }\n    generate();"
                            }
                        },
