                            }
                        },
                        "structure": {
                            "title": "Structure",
                            "json": {
                                "dns": {
                                    "rules": [
                                        {
                                            "inbound": [
                                                "mixed-in"
                                            ],
                                            "ip_version": 6,
                                            "query_type": [
                                                "A",
                                                "HTTPS",
                                                32768
                                            ],
                                            "network": "tcp",
                                            "auth_user": [
                                                "usera",
                                                "userb"
                                            ],
                                            "protocol": [
                                                "tls",
                                                "http",
                                                "quic"
                                            ],
                                            "domain": [
                                                "test.com"
                                            ],
                                            "domain_suffix": [
                                                ".cn"
                                            ],
                                            "domain_keyword": [
                                                "test"
                                            ],
                                            "domain_regex": [
                                                "^stun\\..+"
                                            ],
                                            "source_ip_cidr": [
                                                "10.0.0.0/24",
                                                "192.168.0.1"
                                            ],
                                            "source_ip_is_private": false,
                                            "ip_cidr": [
                                                "10.0.0.0/24",
                                                "192.168.0.1"
                                            ],
                                            "ip_is_private": false,
                                            "ip_accept_any": false,
                                            "source_port": [
                                                12345
                                            ],
                                            "source_port_range": [
                                                "1000:2000",
                                                ":3000",
                                                "4000:"
                                            ],
                                            "port": [
                                                80,
                                                443
                                            ],
                                            "port_range": [
                                                "1000:2000",
                                                ":3000",
                                                "4000:"
                                            ],
                                            "process_name": [
                                                "curl"
                                            ],
                                            "process_path": [
                                                "/usr/bin/curl"
                                            ],
                                            "process_path_regex": [
                                                "^/usr/bin/.+"
                                            ],
                                            "package_name": [
                                                "com.termux"
                                            ],
                                            "user": [
                                                "sekai"
                                            ],
                                            "user_id": [
                                                1000
                                            ],
                                            "clash_mode": "direct",
                                            "network_type": [
                                                "wifi"
                                            ],
                                            "network_is_expensive": false,
                                            "network_is_constrained": false,
                                            "wifi_ssid": [
                                                "My WIFI"
                                            ],
                                            "wifi_bssid": [
                                                "00:00:00:00:00:00"
                                            ],
                                            "rule_set": [
                                                "geoip-cn",
                                                "geosite-cn"
                                            ],
                                            "rule_set_ip_cidr_match_source": false,
                                            "rule_set_ip_cidr_accept_empty": false,
                                            "invert": false,
                                            "outbound": [
                                                "direct"
                                            ],
                                            "action": "route",
                                            "server": "local",
                                            "rule_set_ipcidr_match_source": false,
                                            "geosite": [
                                                "cn"
                                            ],
                                            "source_geoip": [
                                                "private"
                                            ],
                                            "geoip": [
                                                "cn"
                                            ]
                                        },
                                        {
                                            "type": "logical",
                                            "mode": "and",
                                            "rules": [],
                                            "action": "route",
                                            "server": "local"
                                        }
                                    ]
                                }
                            },
                            "note": "You can ignore the JSON Array [] tag when the content is only one item"
                        },
                        "default_fields": {
                            "title": "Default Fields",
                            "description": "The default rule uses the following matching logic:\n(`domain` || `domain_suffix` || `domain_keyword` || `domain_regex` || `geosite`) &&\n(`port` || `port_range`) &&\n(`source_geoip` || `source_ip_cidr` ｜｜ `source_ip_is_private`) &&\n(`source_port` || `source_port_range`) &&\n`other fields`\n\nAdditionally, included rule-sets can be considered merged rather than as a single rule sub-item."
                        },
                        "fields": {
                            "title": "Fields",
                            "inbound": {
                                "title": "inbound",
                                "description": "Tags of [Inbound](/configuration/inbound/)."
                            },
                            "ip_version": {
                                "title": "ip_version",
                                "description": "4 (A DNS query) or 6 (AAAA DNS query). Not limited if empty."
