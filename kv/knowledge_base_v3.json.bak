                        "fields": {
                            "title": "Fields",
                            "rules": {
                                "title": "rules",
                                "description": "List of [Route Rule](./rule/)"
                            },
                            "rule_set": {
                                "title": "rule_set",
                                "description": "List of [rule-set](/configuration/rule-set/)",
                                "since": "Since sing-box 1.8.0"
                            },
                            "final": {
                                "title": "final",
                                "description": "Default outbound tag. the first outbound will be used if empty."
                            },
                            "auto_detect_interface": {
                                "title": "auto_detect_interface",
                                "description": "Bind outbound connections to the default NIC by default to prevent routing loops under tun.",
                                "note": "Only supported on Linux, Windows and macOS. Takes no effect if `outbound.bind_interface` is set."
                            },
                            "override_android_vpn": {
                                "title": "override_android_vpn",
                                "description": "Accept Android VPN as upstream NIC when `auto_detect_interface` enabled.",
                                "note": "Only supported on Android."
                            },
                            "default_interface": {
                                "title": "default_interface",
                                "description": "Bind outbound connections to the specified NIC by default to prevent routing loops under tun.",
                                "note": "Only supported on Linux, Windows and macOS. Takes no effect if `auto_detect_interface` is set."
                            },
                            "default_mark": {
                                "title": "default_mark",
                                "description": "Set routing mark by default.",
                                "note": "Only supported on Linux. Takes no effect if `outbound.routing_mark` is set."
                            },
                            "default_domain_resolver": {
                                "title": "default_domain_resolver",
                                "description": "See [Dial Fields](/configuration/shared/dial/#domain_resolver) for details.",
                                "since": "Since sing-box 1.12.0",
                                "note": "Can be overrides by `outbound.domain_resolver`."
                            },
                            "default_network_strategy": {
                                "title": "default_network_strategy",
                                "description": "See [Dial Fields](/configuration/shared/dial/#network_strategy) for details.",
                                "since": "Since sing-box 1.11.0",
                                "note": "Takes no effect if `outbound.bind_interface`, `outbound.inet4_bind_address` or `outbound.inet6_bind_address` is set. Can be overrides by `outbound.network_strategy`. Conflicts with `default_interface`."
                            },
                            "default_network_type": {
                                "title": "default_network_type",
                                "description": "See [Dial Fields](/configuration/shared/dial/#network_type) for details.",
                                "since": "Since sing-box 1.11.0"
                            },
                            "default_fallback_network_type": {
