                    "hysteria2": {
                        "title": "Hysteria 2",
                        "description": "Hysteria 2 is a simple, Chinese-made protocol based on QUIC. The selling point is Brutal, a congestion control algorithm that tries to achieve a user-defined bandwidth despite packet loss.",
                        "warning": "Even though GFW rarely blocks UDP-based proxies, such protocols actually have far more obvious characteristics than TCP based proxies.",
                        "specification": {
                            "specification": "[hysteria.network](https://v2.hysteria.network/docs/developers/Protocol/)",
                            "resists_passive_detection": ":material-alert:",
                            "resists_active_probes": ":material-check:"
                        },
                        "password_generator": {
                            "title": ":material-text-box-check: Password Generator",
                            "generate_password_table": {
                                "headers": [
                                    "Generate Password",
                                    "Action"
                                ],
                                "rows": [
                                    {
                                        "generate_password": "<code id=\"password\"><code>",
                                        "action": "<button class=\"md-button\" onclick=\"generate()\">Refresh</button>"
                                    }
                                ],
                                "script": "function generate() {\n        const array = new Uint8Array(16);\n        window.crypto.getRandomValues(array);\n        document.getElementById(\"password\").textContent = btoa(String.fromCharCode.apply(null, array));\n    }\n    generate();"
                            }
                        },
                        "difference_from_official_hysteria": {
                            "title": ":material-alert: Difference from official Hysteria",
                            "description": "The official program supports an authentication method called **userpass**, which essentially uses a combination of `<username>:<password>` as the actual password, while sing-box does not provide this alias. To use sing-box with the official program, you need to fill in that combination as the actual password."
                        },
                        "server_example": {
                            "title": ":material-server: Server Example",
                            "note": "Replace `up_mbps` and `down_mbps` values with the actual bandwidth of your server.",
                            "with_local_certificate": {
                                "title": ":material-harddisk: With local certificate",
                                "configuration": {
