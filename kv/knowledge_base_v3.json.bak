                            "title": "Fields",
                            "up_down": {
                                "title": "up, down",
                                "description": "==Required== Format: `[Integer] [Unit]` e.g. `100 Mbps, 640 KBps, 2 Gbps` Supported units (case sensitive, b = bits, B = bytes, 8b=1B): bps (bits per second) Bps (bytes per second) Kbps (kilobits per second) KBps (kilobytes per second) Mbps (megabits per second) MBps (megabytes per second) Gbps (gigabits per second) GBps (gigabytes per second) Tbps (terabits per second) TBps (terabytes per second)"
                            },
                            "up_mbps_down_mbps": {
                                "title": "up_mbps, down_mbps",
                                "description": "==Required== `up, down` in Mbps."
                            },
                            "obfs": {
                                "title": "obfs",
                                "description": "Obfuscated password."
                            },
